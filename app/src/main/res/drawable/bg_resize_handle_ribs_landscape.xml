<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background_primary"/>
        </shape>
    </item>

    <item android:gravity="center">
        <shape android:shape="oval">
            <size
                android:width="4dp"
                android:height="4dp"/>
            <solid android:color="?attr/colorOnSurface"/>
        </shape>
    </item>

    <item
        android:gravity="center"
        android:top="18dp"> <shape android:shape="oval">
        <size
            android:width="4dp"
            android:height="4dp"/>
        <solid android:color="?attr/colorOnSurface"/>
    </shape>
    </item>

    <item
        android:gravity="center"
        android:bottom="18dp"> <shape android:shape="oval">
        <size
            android:width="4dp"
            android:height="4dp"/>
        <solid android:color="?attr/colorOnSurface"/>
    </shape>
    </item>

</layer-list>