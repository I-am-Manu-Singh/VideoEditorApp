<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface">

        <!-- Vertical Split Guideline -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/landscapeSplitGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.45" />

        <!-- LEFT PANE: Preview & Controls -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/previewContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="?attr/colorSurface"
            app:layout_constraintBottom_toTopOf="@id/playbackControls"
            app:layout_constraintEnd_toStartOf="@id/landscapeSplitGuideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.media3.ui.PlayerView
                android:id="@+id/playerView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:resize_mode="fit"
                app:use_controller="false" />

            <!-- Empty State Placeholder -->
            <LinearLayout
                android:id="@+id/layoutEmptyPreview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:visibility="visible">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_video_camera"
                    app:tint="?attr/colorSecondary"
                    android:alpha="0.2" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap + to start your masterpiece"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:alpha="0.6"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/interactiveOverlayLayer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="@id/playerView"
                app:layout_constraintEnd_toEndOf="@id/playerView"
                app:layout_constraintStart_toStartOf="@id/playerView"
                app:layout_constraintTop_toTopOf="@id/playerView">

                <com.example.videoeditorapp.ui.preview.OverlayManipulationView
                    android:id="@+id/overlayManipulationView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />
            </FrameLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:indeterminateTint="?attr/colorSecondary" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Playback Controls (Bottom of Left Pane) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/playbackControls"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/landscapeSplitGuideline"
            app:layout_constraintBottom_toBottomOf="parent">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTimeCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:paddingStart="8dp"
                        android:text="00:00:00"
                        android:textColor="?attr/colorSecondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    
                    <TextView
                        android:id="@+id/tvDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="roboto"
                        android:paddingStart="8dp"
                        android:text="00:00:00"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:alpha="0.7"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/playbackHub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnPrevClip"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/white_20"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="6dp"
                            android:src="@drawable/ic_skip_previous"
                            app:tint="?attr/colorOnSurface" />
                    </com.google.android.material.card.MaterialCardView>

                    <ImageView
                        android:id="@+id/btnFrameBack"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_chevron_left"
                        app:tint="?attr/colorOnSurface"
                        android:alpha="0.6" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginHorizontal="4dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/brand_accent"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="4dp">
                        <ImageView
                            android:id="@+id/btnPlayPause"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            android:src="@drawable/ic_play"
                            app:tint="@color/selector_play_button_tint" />
                    </com.google.android.material.card.MaterialCardView>

                    <ImageView
                        android:id="@+id/btnFrameFwd"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="?attr/colorOnSurface"
                        android:alpha="0.6" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnNextClip"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/white_20"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="6dp"
                            android:src="@drawable/ic_skip_next"
                            app:tint="?attr/colorOnSurface" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnStop"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="10dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#33FF5252"
                    app:cardBackgroundColor="#1AFF5252"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="8dp"
                        android:src="@drawable/ic_stop"
                        app:tint="#FF5252" />
                </com.google.android.material.card.MaterialCardView>

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- RIGHT PANE: Toolbar, Timeline, Bottom Nav -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:background="?attr/colorSurface"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/landscapeSplitGuideline"
            app:layout_constraintTop_toTopOf="parent">

            <HorizontalScrollView
                android:id="@+id/timelineToolbar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/colorSurface"
                android:scrollbars="none"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp">

                    <!-- SELECT -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnSelect"
                        android:layout_width="56dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="2dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_cursor"
                                app:tint="?attr/colorSecondary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SELECT"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="7sp"
                                android:fontFamily="sans-serif-black"
                                android:alpha="0.8" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- SPLIT -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnSplit"
                        android:layout_width="56dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="10dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardBackgroundColor="@color/white_05"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_content_cut"
                                app:tint="?attr/colorSecondary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SPLIT"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="7sp"
                                android:fontFamily="sans-serif-black"
                                android:alpha="0.8" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- TRIM -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnTrim"
                        android:layout_width="56dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="10dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardBackgroundColor="@color/white_05"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_open_in_full"
                                app:tint="?attr/colorSecondary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TRIM"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="7sp"
                                android:fontFamily="sans-serif-black"
                                android:alpha="0.8" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- SPEED -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnSpeed"
                        android:layout_width="56dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="10dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardBackgroundColor="@color/white_05"
                        app:cardElevation="0dp">
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <View
                                android:id="@+id/viewSpeedFill"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_gravity="bottom"
                                android:background="@color/brand_accent"
                                android:alpha="0.2" />
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_speed"
                                    app:tint="?attr/colorSecondary" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="SPEED"
                                    android:textColor="?attr/colorOnSurface"
                                    android:textSize="7sp"
                                    android:fontFamily="sans-serif-black"
                                    android:alpha="0.8" />
                            </LinearLayout>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- VOLUME -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnVolume"
                        android:layout_width="56dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="10dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardBackgroundColor="@color/white_05"
                        app:cardElevation="0dp">
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <View
                                android:id="@+id/viewVolumeFill"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_gravity="bottom"
                                android:background="@color/brand_secondary"
                                android:alpha="0.2" />
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_volume_up"
                                    app:tint="?attr/colorSecondary" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="VOLUME"
                                    android:textColor="?attr/colorOnSurface"
                                    android:textSize="7sp"
                                    android:fontFamily="sans-serif-black"
                                    android:alpha="0.8" />
                            </LinearLayout>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                     <!-- COPY -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnCopyClip"
                        android:layout_width="56dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="10dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardBackgroundColor="@color/white_05"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_copy"
                                app:tint="?attr/colorSecondary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="COPY"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="7sp"
                                android:fontFamily="sans-serif-black"
                                android:alpha="0.8" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- PASTE (Hidden by default) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnPasteClip"
                        android:layout_width="56dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="10dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardBackgroundColor="@color/white_05"
                        app:cardElevation="0dp"
                        android:visibility="gone">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_paste"
                                app:tint="?attr/colorSecondary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PASTE"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="7sp"
                                android:fontFamily="sans-serif-black"
                                android:alpha="0.8" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- CROP -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnCropClip"
                        android:layout_width="56dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="10dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardBackgroundColor="@color/white_05"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_crop"
                                app:tint="?attr/colorSecondary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CROP"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="7sp"
                                android:fontFamily="sans-serif-black"
                                android:alpha="0.8" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- FRONT -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnMoveToFront"
                        android:layout_width="56dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="10dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardBackgroundColor="@color/white_05"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_layers"
                                app:tint="?attr/colorSecondary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FRONT"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="7sp"
                                android:fontFamily="sans-serif-black"
                                android:alpha="0.8" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- BACK -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnMoveToBack"
                        android:layout_width="56dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="10dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardBackgroundColor="@color/white_05"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_layers"
                                android:rotation="180"
                                app:tint="?attr/colorSecondary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BACK"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="7sp"
                                android:fontFamily="sans-serif-black"
                                android:alpha="0.8" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- DELETE -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnDeleteClip"
                        android:layout_width="56dp"
                        android:layout_height="44dp"
                        app:cardCornerRadius="10dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        app:cardBackgroundColor="@color/white_05"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_delete"
                                app:tint="?attr/colorSecondary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DELETE"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="7sp"
                                android:fontFamily="sans-serif-black"
                                android:alpha="0.8" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/timelineVerticalScroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="?attr/colorSurface"
                android:fillViewport="true"
                android:clipToPadding="false"
                android:overScrollMode="never">

                <com.example.videoeditorapp.ui.timeline.TimelineView
                    android:id="@+id/timelineView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="80dp"
                    android:clipToPadding="false" />
            </androidx.core.widget.NestedScrollView>

            <LinearLayout
                android:id="@+id/bottomNavWrapper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_bottom_bar_rounded"
                android:backgroundTint="?attr/colorSurfaceVariant"
                android:elevation="16dp"
                android:orientation="horizontal">

                <HorizontalScrollView
                    android:id="@+id/bottomNavTabs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fillViewport="true"
                    android:scrollbars="none"
                    android:background="@android:color/transparent">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="8dp">

                        <LinearLayout
                            android:id="@+id/tabEdit"
                            style="@style/CinematicNavTab"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_nav_tab">
                            <ImageView
                                style="@style/CinematicNavIcon"
                                android:src="@drawable/ic_edit"
                                app:tint="@color/nav_icon_tint" />
