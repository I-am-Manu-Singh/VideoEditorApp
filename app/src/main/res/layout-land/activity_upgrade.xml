<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_black">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBackContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="#00D2D3" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="License Center"
                android:textColor="#00D2D3"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                app:layout_constraintStart_toEndOf="@id/btnBackContainer"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:baselineAligned="false"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- LEFT PANE: Essentials & Branding -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.45"
            android:orientation="vertical"
            android:padding="24dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="License Center"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"/>
            
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/white_05"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/white_10"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="Essentials"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="• Precision Cut &amp; Trim\n• HD Output Engine\n• Essential Assets"
                        android:textColor="@color/white_70"
                        android:textSize="10sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvRestorePurchase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Restore your License"
                android:textColor="#00D2D3"
                android:textSize="10sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- RIGHT PANE: Pro & Studio Options -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.55"
            android:overScrollMode="never"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="24dp">

                <!-- MASTER LICENSE -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnUpgradePro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/card_pro_selector"
                    app:strokeColor="@color/card_pro_stroke"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="1.5dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="vertical">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:id="@+id/labelPro"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Master License"
                                android:textColor="@color/card_pro_text"
                                android:textSize="18sp"
                                android:fontFamily="sans-serif-black"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$4.99"
                                android:layout_alignParentEnd="true"
                                android:textColor="@color/card_pro_text"
                                android:textSize="18sp"
                                android:fontFamily="monospace"/>
                        </RelativeLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="• No Watermarks\n• 4K UHD Export Ready"
                            android:textColor="@color/white_70"
                            android:textSize="10sp"
                            android:fontFamily="monospace"/>
                        
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:cardBackgroundColor="#1A00D2D3"
                            app:cardCornerRadius="4dp"
                            app:strokeColor="#4D00D2D3">
                            <TextView
                                android:id="@+id/btnUpgradeProAction"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:text="Activate Now"
                                android:textColor="#00D2D3"
                                android:textSize="8sp"
                                android:fontFamily="monospace"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- STUDIO SUITE -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnUpgradeStudio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/card_studio_selector"
                    app:strokeColor="@color/card_studio_stroke"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="1.5dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="vertical">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:id="@+id/labelStudio"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Studio Suite"
                                android:textColor="@color/card_studio_text"
                                android:textSize="18sp"
                                android:fontFamily="sans-serif-black"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$9.99"
                                android:layout_alignParentEnd="true"
                                android:textColor="@color/card_pro_text"
                                android:textSize="18sp"
                                android:fontFamily="monospace"/>
                        </RelativeLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="• Everything in Master\n• Cloud Asset Sync\n• Team Suite"
                            android:textColor="@color/white_70"
                            android:textSize="10sp"
                            android:fontFamily="monospace"/>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:cardBackgroundColor="#26FF3A3A"
                            app:cardCornerRadius="4dp"
                            app:strokeColor="#4DFF3A3A">
                            <TextView
                                android:id="@+id/btnUpgradeStudioAction"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:text="Activate Now"
                                android:textColor="#FF3A3A"
                                android:textSize="8sp"
                                android:fontFamily="monospace"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
