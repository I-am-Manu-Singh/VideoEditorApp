<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start"
    android:background="@color/bg_deep_black">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_deep_black"
        >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Hero Section (Left Panel) -->
            <FrameLayout
                android:id="@+id/heroPreviewContainer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@color/bg_deep_black"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintWidth_percent="0.3">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_hero_gradient_final"
                    android:alpha="1.0"/>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="42dp"
                    android:paddingTop="100dp"
                    android:paddingBottom="24dp">

                    <LinearLayout
                        android:id="@+id/brandingSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/studio_v4"
                            android:fontFamily="sans-serif-black"
                            android:textColor="#00D2D3"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/creative_suite"
                            android:textColor="#66FFFFFF"
                            android:textSize="8sp"
                            android:letterSpacing="0.3"
                            android:fontFamily="monospace"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/heroHeadline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/hero_headline"
                        android:textAllCaps="true"
                        android:textColor="@color/text_primary"
                        android:textSize="26sp"
                        android:lineHeight="30sp"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="20dp"
                        app:layout_constraintTop_toBottomOf="@id/brandingSection" />

                    <!-- Favorites and Projects Stacked Vertically -->
                    <LinearLayout
                        android:id="@+id/quickActionsLand"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginBottom="90dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnNavFavorites"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="@color/bg_dark_surface"
                        app:strokeWidth="1dp"
                            app:strokeColor="@color/white_10">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="14dp"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_heart"
                                    android:contentDescription="@null"
                                    app:tint="#00D2D3"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/nav_favorites"
                                    android:textColor="@color/text_primary"
                                    android:textSize="11sp"
                                    android:letterSpacing="0.05"
                                    android:fontFamily="sans-serif-black"
                                    android:layout_marginStart="12dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnNavMyProjects"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="@color/bg_dark_surface"
                        app:strokeWidth="1dp"
                            app:strokeColor="@color/white_10">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="14dp"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_folder"
                                    android:contentDescription="@null"
                                    app:tint="#00D2D3"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/nav_projects"
                                    android:textColor="@color/text_primary"
                                    android:textSize="11sp"
                                    android:letterSpacing="0.05"
                                    android:fontFamily="sans-serif-black"
                                    android:layout_marginStart="12dp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                          
                    </LinearLayout>
       
                </androidx.constraintlayout.widget.ConstraintLayout>
         
            </FrameLayout>
 <com.google.android.material.card.MaterialCardView
    android:id="@+id/btnProfile"
    android:layout_width="44dp"
    android:layout_height="44dp"
    android:layout_marginTop="36dp"
    android:layout_marginEnd="24dp"

    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintEnd_toEndOf="@id/heroPreviewContainer"

    app:cardBackgroundColor="@color/white_05"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/white_10">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp"
        android:src="@drawable/ic_person"
        app:tint="#00D2D3"/>

</com.google.android.material.card.MaterialCardView>
            <!-- Scrollable Content Area (Right Panel) -->
           <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="0dp"
    android:id="@+id/rightPanelContainer"
    android:layout_height="match_parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toEndOf="@id/heroPreviewContainer"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintWidth_percent="0.7">

   
    <!-- Scrollable Content -->

    <androidx.core.widget.NestedScrollView
    android:id="@+id/rightPanelScroll"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:clipToPadding="false"
    android:paddingTop="26dp"
    android:paddingBottom="80dp"

    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/labelRecentProjects"
                        style="@style/StealthLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:letterSpacing="0.2"
                        android:text="@string/recent_projects"
                        android:textSize="10sp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <ImageButton
                        android:id="@+id/btnResumeProject"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="24dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        app:tint="#00D2D3"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:layout_constraintTop_toTopOf="@id/labelRecentProjects"
                        app:layout_constraintBottom_toBottomOf="@id/labelRecentProjects"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecentProjects"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:clipToPadding="false"
                        android:layout_marginTop="12dp"
                        android:overScrollMode="never"
                        android:nestedScrollingEnabled="false"
                        app:layout_constraintTop_toBottomOf="@id/labelRecentProjects"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardEmptyRecent"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_marginHorizontal="24dp"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="@color/white_05"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10"
                        android:visibility="gone"
                        app:layout_constraintTop_toBottomOf="@id/labelRecentProjects"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:padding="16dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_video_camera"
                                android:contentDescription="@null"
                                app:tint="#00D2D3"
                                android:alpha="0.2"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/no_active_sequences"
                                android:textColor="@color/white_30"
                                android:fontFamily="monospace"
                                android:textSize="10sp"
                                android:layout_marginStart="12dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <androidx.constraintlayout.widget.Barrier
                        android:id="@+id/recentProjectsBarrier"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:barrierDirection="bottom"
                        app:constraint_referenced_ids="rvRecentProjects,cardEmptyRecent"/>
                    <TextView
                        android:id="@+id/labelLearningCenter"
                        style="@style/StealthLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginStart="24dp"
                        android:text="@string/learning_center"
                        android:letterSpacing="0.2"
                        android:textSize="10sp"
                        app:layout_constraintTop_toBottomOf="@id/recentProjectsBarrier"
                        app:layout_constraintStart_toStartOf="parent" />

                    <ImageButton
                        android:id="@+id/btnViewAllTutorials"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="24dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        app:tint="#00D2D3"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:layout_constraintTop_toTopOf="@id/labelLearningCenter"
                        app:layout_constraintBottom_toBottomOf="@id/labelLearningCenter"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTutorials"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:paddingHorizontal="16dp"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:nestedScrollingEnabled="false"
                        app:layout_constraintTop_toBottomOf="@id/labelLearningCenter"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <TextView
                        android:id="@+id/labelTrendingAssets"
                        style="@style/StealthLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginStart="24dp"
                        android:text="@string/trending_assets"
                        android:textSize="10sp"
                        android:letterSpacing="0.2"
                        app:layout_constraintTop_toBottomOf="@id/rvTutorials"
                        app:layout_constraintStart_toStartOf="parent" />

                    <ImageButton
                        android:id="@+id/btnViewAllAssets"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="24dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        app:tint="#00D2D3"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:layout_constraintTop_toTopOf="@id/labelTrendingAssets"
                        app:layout_constraintBottom_toBottomOf="@id/labelTrendingAssets"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTrendingAssets"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:paddingHorizontal="16dp"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:nestedScrollingEnabled="false"
                        app:layout_constraintTop_toBottomOf="@id/labelTrendingAssets"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
                 </androidx.core.widget.NestedScrollView>
                </androidx.constraintlayout.widget.ConstraintLayout>
           
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Floating UI Overlays -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnMenuHome"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="36dp"
            android:layout_gravity="top|start"
            app:cardBackgroundColor="@color/white_05"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/white_10">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="@null"
                app:tint="#00D2D3"/>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fabNewProject"
            style="@style/FabNeonStyle"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cornerRadius="8dp"
            android:layout_gravity="end|bottom"
            android:textColor="@color/white"
            app:iconTint="@color/white"
            android:textSize="13sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-black"
            app:icon="@drawable/ic_add_bold"
            app:iconPadding="10dp"
            app:elevation="22dp"
            app:rippleColor="#3300D2D3"/>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <include
        android:id="@+id/navDrawer"
        layout="@layout/layout_main_nav_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
