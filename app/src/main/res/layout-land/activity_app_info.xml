<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_black">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBackContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="#00D2D3" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Studio_V4 Info"
                android:textColor="#00D2D3"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                app:layout_constraintStart_toEndOf="@id/btnBackContainer"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:baselineAligned="false">

        <!-- LEFT PANE: Logo & Title -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.4"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/bg_deep_black">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                app:cardCornerRadius="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="#4D00D2D3"
                app:cardBackgroundColor="@color/bg_dark_elevated">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="2dp"
                    android:src="@drawable/app_logo"
                    android:scaleType="fitCenter"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:text="Studio V4"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvVersion"
                android:text="Stable Production Release"
                android:fontFamily="monospace"
                android:textColor="#00D2D3"
                android:background="@color/white_05"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textSize="9sp"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- RIGHT PANE: Features & Actions -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.6"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:rowOrderPreserved="false"
                    android:useDefaultMargins="true">

                    <!-- Engine Style -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• ENGINE STYLE"
                            android:textColor="#00D2D3"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="High Fidelity"
                            android:textColor="@color/white_50"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Pipeline -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• PIPELINE"
                            android:textColor="#00D2D3"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Frame-Accurate Sync"
                            android:textColor="@color/white_50"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Status -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• STATUS"
                            android:textColor="#00D2D3"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Authorized"
                            android:textColor="@color/white_50"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </GridLayout>

                <View style="@style/StealthDivider" android:layout_marginVertical="12dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white_05"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/white_10">
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="4dp">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRate"
                            style="@style/StealthActionRow"
                            android:text="Rate on Play Store"
                            android:textColor="@color/white_70"
                            android:textSize="12sp"
                            app:icon="@android:drawable/btn_star"
                            app:iconTint="#00D2D3"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnShare"
                            style="@style/StealthActionRow"
                            android:text="Recommend"
                            android:textColor="@color/white_70"
                            android:textSize="12sp"
                            app:icon="@android:drawable/ic_menu_share"
                            app:iconTint="#00D2D3"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLicenses"
                            style="@style/StealthActionRow"
                            android:text="Legal &amp; Privacy"
                            android:textColor="@color/white_70"
                            android:textSize="12sp"
                            app:icon="@drawable/ic_info"
                            app:iconTint="#00D2D3"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:text="© 2026 Cinematic Studio Engine V4"
                    android:textColor="@color/white_20"
                    android:textSize="8sp"
                    android:fontFamily="monospace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
