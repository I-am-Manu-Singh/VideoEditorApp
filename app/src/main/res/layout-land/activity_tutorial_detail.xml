<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_black">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="4dp"
        android:translationZ="50dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBackContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                app:cardBackgroundColor="#CC0D0D0D"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="#00D2D3" />
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- LEFT: Media Preview -->
        <FrameLayout
            android:id="@+id/previewContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.45">
            <ImageView
                android:id="@+id/ivTutorialCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/temp_cinematic" />
        </FrameLayout>

        <!-- RIGHT: Content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.55"
            android:overScrollMode="never"
            android:background="@color/bg_deep_black">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="80dp"
                android:paddingBottom="40dp">

                <TextView
                    android:id="@+id/chipLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#1A00D2D3"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="Level: Standard"
                    android:textColor="#00D2D3"
                    android:textSize="9sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvTutorialTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tutorial Title"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textAllCaps="true"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="12dp"/>

                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="#00D2D3"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:id="@+id/tvTutorialContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Here is where the step-by-step tutorial content will go. It will explain how to achieve the effect or technique described in the title."
                    android:textColor="#A0FFFFFF"
                    android:textSize="14sp"
                    android:lineHeight="22sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="32dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWatchVideo"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Watch Masterclass Video"
                    android:textColor="#000000"
                    app:icon="@drawable/ic_play"
                    app:iconTint="#000000"
                    app:iconGravity="textStart"
                    app:backgroundTint="#00D2D3"
                    app:cornerRadius="8dp"
                    android:textSize="12sp"
                    android:letterSpacing="0.05"
                    android:fontFamily="sans-serif-black"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:text="Verified Academy Module"
                    android:textColor="#20FFFFFF"
                    android:textSize="8sp"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
