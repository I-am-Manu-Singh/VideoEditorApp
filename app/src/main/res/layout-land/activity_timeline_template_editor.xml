<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:openDrawer="end">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        
        <!-- Root Content -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Compact Toolbar for Landscape -->
            <LinearLayout
                android:id="@+id/toolbarTimeline"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/colorSurface"
                android:paddingHorizontal="8dp"
                android:elevation="4dp"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnBackContainer"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="10dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="8dp"
                        android:src="@drawable/ic_back"
                        app:tint="?attr/colorSecondary" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvToolbarTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="12dp"
                    android:fontFamily="sans-serif-black"
                    android:text="TIMELINE EDITOR"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <!-- Action Buttons Group -->
                 <LinearLayout
                    android:id="@+id/btnUndoContainer"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:id="@+id/btnUndo"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_undo"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnRedoContainer"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:id="@+id/btnRedo"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_redo"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnInfoContainer"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless">
                    <ImageView
                        android:id="@+id/btnInfo"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_info"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                 <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnSaveContainer"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardBackgroundColor="?attr/colorSecondaryContainer"
                        app:cardCornerRadius="10dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="?attr/colorSecondary">
                    <ImageView
                        android:id="@+id/btnSave"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="8dp"
                        android:src="@drawable/ic_save"
                        app:tint="?attr/colorSecondary" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Main Split Editor (Using existing Landscape Preview which handles split) -->
            <include
                android:id="@+id/editorPreview"
                layout="@layout/view_editor_preview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@id/toolbarTimeline"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- FAB Menu (Positioned for Landscape) -->
        <LinearLayout
            android:id="@+id/fabMenuContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:gravity="center_horizontal"
            app:layout_behavior="com.google.android.material.behavior.HideBottomViewOnScrollBehavior">

             <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabActionHub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:fabSize="mini"
                android:layout_marginBottom="12dp"
                android:src="@drawable/ic_hub"
                app:tint="?attr/colorOnPrimary"
                app:backgroundTint="?attr/colorSecondary"
                android:visibility="gone"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabActionExport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:fabSize="mini"
                android:layout_marginBottom="12dp"
                android:src="@drawable/ic_export"
                app:tint="?attr/colorOnPrimary"
                app:backgroundTint="?attr/colorPrimary"
                android:visibility="gone"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAdd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:srcCompat="@drawable/ic_plus"
                app:tint="?attr/colorOnPrimary"
                android:backgroundTint="?attr/colorPrimary" />
        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Side Drawer can remain same or be hidden in Landscape mode if desired, but we keep structure -->

</androidx.drawerlayout.widget.DrawerLayout>
