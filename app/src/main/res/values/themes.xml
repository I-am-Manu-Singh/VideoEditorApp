<?xml version="1.0" encoding="utf-8"?>
    <resources xmlns:tools="http://schemas.android.com/tools">
        <style name="Theme.VideoEditorApp.Dialog" parent="ThemeOverlay.Material3.Dialog.Alert">
            <item name="android:windowBackground">@android:color/transparent</item>
            <item name="android:windowIsFloating">true</item>
            <item name="android:backgroundDimEnabled">true</item>
            <item name="android:backgroundDimAmount">0.4</item>
            <item name="colorPrimary">@color/brand_primary</item>
            <item name="colorSurface">@color/bg_dark_elevated</item>
        </style>
        <style name="Theme.VideoEditorApp" parent="Theme.Material3.DayNight.NoActionBar">
            <item name="colorPrimary">#00D2D3</item>
            <item name="android:tint">#00D2D3</item>

            <item name="android:statusBarColor">@android:color/transparent</item>
            <item name="android:navigationBarColor">@android:color/transparent</item>
            <item name="android:windowLightStatusBar">true</item>
            <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>
            <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="p">shortEdges</item>

            <item name="colorSurface">@color/bg_light_surface</item>
            <item name="colorOnSurface">@color/text_high_emphasis_light</item>
            <item name="colorSurfaceVariant">@color/bg_light_elevated</item>
            <item name="colorOnSurfaceVariant">@color/text_medium_emphasis_light</item>
            <item name="colorOutline">@color/bg_light_divider</item>

            <item name="android:windowBackground">@color/bg_light_surface</item>

            <item name="android:alertDialogTheme">@style/Theme.VideoEditorApp.Dialog</item>
            <item name="materialAlertDialogTheme">@style/Theme.VideoEditorApp.Dialog</item>
        </style>

        <style name="Theme.VideoEditorApp.Dark" parent="Theme.VideoEditorApp">
            <item name="android:windowLightStatusBar">false</item>
            <item name="colorSurface">#000000</item>
            <item name="colorOnSurface">#FFFFFF</item>
            <item name="colorSurfaceVariant">#0D0D0D</item>
            <item name="colorOnSurfaceVariant">#80FFFFFF</item>
            <item name="colorOutline">#33FFFFFF</item>

            <item name="android:textColorPrimary">#FFFFFF</item>
            <item name="android:textColorSecondary">#80FFFFFF</item>
            <item name="android:windowBackground">#000000</item>
        </style>

        <style name="CinematicNavIcon">
            <item name="android:layout_width">24dp</item>
            <item name="android:layout_height">24dp</item>
            <item name="android:alpha">0.7</item>
            <item name="android:tint">#FFFFFF</item>
        </style>

        <style name="CinematicNavLabel">
            <item name="android:layout_width">wrap_content</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:layout_marginTop">6dp</item>
            <item name="android:fontFamily">monospace</item>
            <item name="android:textSize">8sp</item>
            <item name="android:letterSpacing">0.1</item>
            <item name="android:textColor">#80FFFFFF</item>
            <item name="android:textAllCaps">true</item>
        </style>

        <style name="StealthActionRow">
            <item name="android:layout_width">match_parent</item>
            <item name="android:layout_height">44dp</item>
            <item name="android:gravity">center_vertical</item>
            <item name="android:background">?attr/selectableItemBackground</item>
            <item name="android:clickable">true</item>
            <item name="android:paddingLeft">12dp</item>
            <item name="android:paddingRight">12dp</item>
        </style>

        <style name="StealthActionTitle">
            <item name="android:layout_width">wrap_content</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:textColor">#FFFFFF</item>
            <item name="android:textSize">12sp</item>
            <item name="android:fontFamily">sans-serif-black</item>
            <item name="android:textAllCaps">true</item>
            <item name="android:letterSpacing">0.05</item>
        </style>

        <style name="StealthActionSub">
            <item name="android:layout_width">wrap_content</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:textColor">#00D2D3</item>
            <item name="android:textSize">9sp</item>
            <item name="android:alpha">0.6</item>
            <item name="android:fontFamily">monospace</item>
            <item name="android:textAllCaps">true</item>
        </style>

        <style name="StealthLabel">
            <item name="android:layout_width">wrap_content</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:layout_marginTop">20dp</item>
            <item name="android:fontFamily">monospace</item>
            <item name="android:textColor">#00D2D3</item>
            <item name="android:textSize">9sp</item>
            <item name="android:letterSpacing">0.1</item>
            <item name="android:alpha">0.7</item>
            <item name="android:textAllCaps">true</item>
        </style>

        <style name="StealthSlider">
            <item name="android:layout_width">0dp</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="thumbColor">#00D2D3</item>
            <item name="trackColorActive">#00D2D3</item>
            <item name="trackColorInactive">#33FFFFFF</item>
            <item name="haloColor">#1A00D2D3</item>
        </style>

        <style name="StealthToggleBtn" parent="Widget.MaterialComponents.Button.OutlinedButton">
            <item name="android:insetTop">0dp</item>
            <item name="android:insetBottom">0dp</item>
            <item name="android:fontFamily">monospace</item>
            <item name="android:textSize">10sp</item>
            <item name="android:textColor">#FFFFFF</item>
            <item name="strokeColor">#33FFFFFF</item>
            <item name="android:textAllCaps">true</item>
        </style>

        <style name="DialogRoundedCorners">
            <item name="cornerFamily">rounded</item>
            <item name="cornerSize">16dp</item>
        </style>
    <style name="CinematicTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>
    <style name="NavDrawerItemStealth">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="NavTextStealth">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="StealthActionIcon">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
        <item name="android:tint">#FFFFFF</item>
        <item name="android:alpha">0.7</item>
    </style>
    <style name="StealthActionText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginLeft">16dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.1</item>
    </style>
    <style name="CinematicNavTab">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
    <style name="StealthDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#1AFFFFFF</item>
    </style>

    <style name="ColorChannelLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">#80FFFFFF</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="ColorChannelValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#00D2D3</item>
    </style>

    <style name="StealthSeekBar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:progressTint">#00D2D3</item>
        <item name="android:thumbTint">#00D2D3</item>
    </style>

    <style name="StealthActionTextContainer">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginLeft">16dp</item>
        <item name="android:orientation">vertical</item>
    </style>
    <style name="StealthFeatureCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="cardBackgroundColor">@color/bg_dark_elevated</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/white_05</item>
    </style>

    <style name="StealthFeatureContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="StealthFeatureTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">11sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>

    <style name="StealthFeatureDesc">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">9sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/white_30</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <style name="StealthTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">0.1</item>
    </style>
    <style name="FabNeonStyle" parent="Widget.MaterialComponents.ExtendedFloatingActionButton">
        <item name="shapeAppearanceSmallComponent">@style/FabRoundShape</item>
        <item name="shapeAppearanceMediumComponent">@style/FabRoundShape</item>
        <item name="shapeAppearanceLargeComponent">@style/FabRoundShape</item>
        <item name="iconTint">@android:color/black</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="backgroundTint">#00D2D3</item>
    </style>

    <style name="FabRoundShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Theme.VideoEditorApp.BottomSheet" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/transparent</item>

        <!-- Kill Material 3 shape -->
        <item name="shapeAppearanceSmallComponent">@null</item>
        <item name="shapeAppearanceMediumComponent">@null</item>
        <item name="shapeAppearanceLargeComponent">@null</item>

        <!-- Remove color surfaces -->
        <item name="colorSurface">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>
    <style name="Theme.VideoEditorApp.BottomSheet.Dark" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.4</item>
    </style>

    </resources>