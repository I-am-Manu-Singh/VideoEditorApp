<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/bg_deep_black">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_verified"
                app:tint="@color/brand_accent"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verification Required"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter the 4-digit security code sent to your email"
                android:textColor="#66FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginTop="12dp" />

            <LinearLayout
                android:id="@+id/otpContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="48dp"
                android:gravity="center">

                <EditText
                    android:id="@+id/etOtp1"
                    style="@style/OtpInputStyle" />
                <EditText
                    android:id="@+id/etOtp2"
                    style="@style/OtpInputStyle"
                    android:layout_marginStart="16dp" />
                <EditText
                    android:id="@+id/etOtp3"
                    style="@style/OtpInputStyle"
                    android:layout_marginStart="16dp" />
                <EditText
                    android:id="@+id/etOtp4"
                    style="@style/OtpInputStyle"
                    android:layout_marginStart="16dp" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerify"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="VERIFY IDENTITY"
                android:backgroundTint="@color/brand_accent"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                app:cornerRadius="12dp"
                android:layout_marginTop="48dp" />

            <TextView
                android:id="@+id/tvResend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DIDN'T RECEIVE CODE? RESEND"
                android:textColor="@color/white_30"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginTop="32dp"
                android:padding="16dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
