<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="@color/bg_deep_black">

<View
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_grid_pattern"
    android:alpha="0.05" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.05"
        android:background="@drawable/bg_grid_pattern" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="bottom"
        android:padding="32dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="84dp"
            android:layout_height="84dp"
            app:cardBackgroundColor="@color/white_05"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/white_10">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp"
                android:src="@mipmap/ic_app_logo"
                android:scaleType="fitCenter"
                app:tint="#FFFFFF" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUILD.26"
                android:textColor="#00D2D3"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:alpha="0.6"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STUDIO V4"
                android:textSize="38sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.02"
                android:textAllCaps="true"
                android:textColor="#FFFFFF"
                android:lineHeight="42sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="CINEMATIC_PRODUCTION_SUITE"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:textColor="#00D2D3" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:background="@color/white_10" />

</FrameLayout>