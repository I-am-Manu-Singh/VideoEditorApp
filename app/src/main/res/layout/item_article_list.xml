<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white_05"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/white_10">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="90dp"
            android:layout_height="match_parent"
            app:cardBackgroundColor="@color/bg_dark_elevated"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/white_05">

            <ImageView
                android:id="@+id/ivArticleThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/temp_tutorial_bg"
                android:alpha="0.6"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvArticleTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Advanced Color Grading"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="0.02"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvArticleTags"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cinematic • Lighting • Ultra HD"
                android:textColor="#00D2D3"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:alpha="0.8"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_back"
            android:rotation="180"
            app:tint="#00D2D3"
            android:alpha="0.5"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>