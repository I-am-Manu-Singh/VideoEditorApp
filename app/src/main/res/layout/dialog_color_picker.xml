<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#F2000000"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#3300D2D3">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/dialogHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:background="#00D2D3" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="COLOR_ENGINE // RGB_INPUT"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/previewWrapper"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="0dp"
            app:strokeWidth="2dp"
            app:strokeColor="#1AFFFFFF"
            app:layout_constraintTop_toBottomOf="@id/dialogHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:id="@+id/viewPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#00D2D3" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilHex"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="HEX_CODE"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="#00D2D3"
            app:hintTextColor="#00D2D3"
            app:layout_constraintTop_toBottomOf="@id/previewWrapper"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnCopyHex"
            android:layout_marginEnd="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHex"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:textSize="15sp"
                android:inputType="textNoSuggestions|textCapCharacters"
                android:maxLength="7"/>
        </com.google.android.material.textfield.TextInputLayout>

        <ImageButton
            android:id="@+id/btnCopyHex"
            android:layout_width="48dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_list"
            android:background="@drawable/bg_tag_glass"
            app:layout_constraintBottom_toBottomOf="@id/tilHex"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tilHex"
            app:tint="#00D2D3" />

        <TextView
            android:id="@+id/tvRedLabel"
            style="@style/ColorChannelLabel"
            android:text="R_CHANNEL"
            android:textColor="#FF5252"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilHex"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/tvRedValue"
            style="@style/ColorChannelValue"
            android:text="255"
            android:textColor="#FF5252"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvRedLabel"/>

        <SeekBar
            android:id="@+id/seekRedDialog"
            style="@style/StealthSeekBar"
            android:progressTint="#FF5252"
            android:thumbTint="#FF5252"
            app:layout_constraintTop_toBottomOf="@id/tvRedLabel" />

        <TextView
            android:id="@+id/tvGreenLabel"
            style="@style/ColorChannelLabel"
            android:text="G_CHANNEL"
            android:textColor="#69F0AE"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/seekRedDialog" />

        <TextView
            android:id="@+id/tvGreenValue"
            style="@style/ColorChannelValue"
            android:text="255"
            android:textColor="#69F0AE"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvGreenLabel"/>

        <SeekBar
            android:id="@+id/seekGreenDialog"
            style="@style/StealthSeekBar"
            android:progressTint="#69F0AE"
            android:thumbTint="#69F0AE"
            app:layout_constraintTop_toBottomOf="@id/tvGreenLabel" />

        <TextView
            android:id="@+id/tvBlueLabel"
            style="@style/ColorChannelLabel"
            android:text="B_CHANNEL"
            android:textColor="#448AFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/seekGreenDialog" />

        <TextView
            android:id="@+id/tvBlueValue"
            style="@style/ColorChannelValue"
            android:text="255"
            android:textColor="#448AFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvBlueLabel"/>

        <SeekBar
            android:id="@+id/seekBlueDialog"
            style="@style/StealthSeekBar"
            android:progressTint="#448AFF"
            android:thumbTint="#448AFF"
            app:layout_constraintTop_toBottomOf="@id/tvBlueLabel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="APPLY_COLOR_PARAMS"
            android:textColor="#000000"
            android:fontFamily="sans-serif-black"
            android:backgroundTint="#00D2D3"
            android:letterSpacing="0.05"
            app:cornerRadius="10dp"
            app:layout_constraintTop_toBottomOf="@id/seekBlueDialog"
            android:layout_marginTop="32dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>