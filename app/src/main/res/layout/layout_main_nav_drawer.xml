<?xml version='1.0' encoding='utf-8'?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/navigationDrawer" android:layout_width="300dp" android:layout_height="match_parent" android:layout_gravity="start" app:cardBackgroundColor="@color/dialog_background" app:cardElevation="0dp" android:visibility="invisible" app:strokeWidth="1dp" app:strokeColor="@color/white_10">

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">

        <include android:id="@+id/navHeader" layout="@layout/nav_header_main" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@drawable/bg_line_glow_cyan" android:alpha="0.3" />

        <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:fillViewport="true" android:background="@color/bg_deep_black" android:paddingLeft="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingVertical="24dp" android:paddingHorizontal="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_workspace" android:textColor="@color/brand_accent" android:textSize="12sp" android:letterSpacing="0.2" android:fontFamily="monospace" android:layout_marginBottom="16dp" android:layout_marginStart="12dp" />

                <LinearLayout android:id="@+id/navBtnNewProject" style="@style/NavDrawerItemStealth">
                    <ImageView style="@style/NavIconStealth" android:src="@drawable/ic_add" android:contentDescription="@null" />
                    <TextView style="@style/NavTextStealth" android:text="@string/nav_create_project" />
                </LinearLayout>

                <LinearLayout android:id="@+id/navBtnFavorites" style="@style/NavDrawerItemStealth">
                    <ImageView style="@style/NavIconStealth" android:src="@drawable/ic_heart" android:contentDescription="@null" />
                    <TextView style="@style/NavTextStealth" android:text="@string/nav_favorites" />
                </LinearLayout>

                <LinearLayout android:id="@+id/navBtnProjects" style="@style/NavDrawerItemStealth">
                    <ImageView style="@style/NavIconStealth" android:src="@drawable/ic_folder" android:contentDescription="@null" />
                    <TextView style="@style/NavTextStealth" android:text="@string/nav_project_manager" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="32dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_archive" android:textColor="@color/brand_accent" android:textSize="12sp" android:letterSpacing="0.2" android:fontFamily="monospace" android:layout_marginBottom="16dp" android:layout_marginStart="12dp" />
                <LinearLayout android:id="@+id/navBtnMarketplace" style="@style/NavDrawerItemStealth">
                    <ImageView style="@style/NavIconStealth" android:src="@drawable/ic_hub" android:contentDescription="@null" />
                    <TextView style="@style/NavTextStealth" android:text="@string/nav_assets_hub" />
                </LinearLayout>
                <LinearLayout android:id="@+id/navBtnTutorials" style="@style/NavDrawerItemStealth">
                    <ImageView style="@style/NavIconStealth" android:src="@drawable/ic_play" android:contentDescription="@null" />
                    <TextView style="@style/NavTextStealth" android:text="@string/nav_documentation" />
                </LinearLayout>
                <LinearLayout android:id="@+id/navBtnHelp" style="@style/NavDrawerItemStealth">
                    <ImageView style="@style/NavIconStealth" android:src="@drawable/ic_help" app:tint="@color/text_primary" android:contentDescription="@null" />
                    <TextView style="@style/NavTextStealth" android:text="@string/nav_help_support" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />



                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/white_05" android:layout_marginVertical="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_utilities" android:textColor="@color/brand_accent" android:textSize="12sp" android:fontFamily="monospace" android:letterSpacing="0.2" android:layout_marginTop="24dp" android:layout_marginBottom="12dp" android:layout_marginStart="12dp" />
                <LinearLayout android:id="@+id/navBtnAppInfo" style="@style/NavDrawerItemStealth">
                    <ImageView style="@style/NavIconStealth" android:src="@drawable/ic_menu" app:tint="@color/text_primary" android:contentDescription="@null" />
                    <TextView style="@style/NavTextStealth" android:text="@string/nav_studio_info" />
                </LinearLayout>

                <LinearLayout android:id="@+id/layoutNavSettings" style="@style/NavDrawerItemStealth">
                    <ImageView style="@style/NavIconStealth" android:src="@drawable/ic_settings" app:tint="@color/red_400" android:contentDescription="@null" />
                    <TextView style="@style/NavTextStealth" android:textColor="@color/red_400" android:text="@string/nav_system_settings" />
                </LinearLayout>

                <LinearLayout android:id="@+id/navBtnUpgrade" style="@style/NavDrawerItemStealth">
                    <ImageView style="@style/NavIconStealth" android:src="@drawable/ic_crown" app:tint="@color/brand_accent" android:contentDescription="@null" />
                    <TextView style="@style/NavTextStealth" android:textColor="@color/brand_accent" android:alpha="0.6" android:text="@string/nav_premium_upgrade" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>