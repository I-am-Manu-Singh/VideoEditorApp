<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/bg_deep_black"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/white_10">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/white_10"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PROJECT PARAMETERS"
        android:textColor="@color/brand_accent"
        android:textSize="12sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvRecommendedSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/brand_accent"
        android:gravity="center_horizontal"
        android:textSize="12sp"
        android:layout_marginBottom="24dp"/>

    <!-- Aspect Ratio -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Canvas Aspect Ratio"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="12dp"/>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleAspectRatio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true"
        android:layout_marginBottom="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRatio916"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="9:16"
            android:textSize="11sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRatio169"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="16:9"
            android:textSize="11sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRatio219"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="21:9"
            android:textSize="11sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRatio11"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1:1"
            android:textSize="11sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRatioOriginal"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ORIGINAL"
            android:textSize="10sp"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Resolution -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Export Resolution"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="12dp"/>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleResolution"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true"
        android:layout_marginBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRes720"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="720P"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRes1080"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1080P"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRes2K"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2K"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRes4K"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="4K / UHD"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResOriginal"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ORIGINAL"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>
    <TextView
        android:id="@+id/tvExportDimensions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:text="1920 × 1080"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"/>
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveProjectSettings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="SAVE PROJECT"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/white_10"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.1"
        android:layout_marginBottom="12dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/white_20"/>
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplySettings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="EXPORT VIDEO"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/brand_accent"
        android:textColor="#000000"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.1"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>