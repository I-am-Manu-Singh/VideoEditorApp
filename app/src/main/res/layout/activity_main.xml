<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start"
    android:background="@color/bg_deep_black">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_deep_black">

        <!-- SCROLLING CONTENT (unchanged) -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            android:fillViewport="true"
            android:overScrollMode="never">

            <!-- your entire huge layout here -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="440dp"
                    android:background="@color/bg_deep_black">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0.4"
                        android:scaleType="centerCrop"
                        android:src="@drawable/temp_cinematic_hero" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_hero_gradient_final" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0.05"
                        android:background="@drawable/bg_grid_pattern" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="24dp"
                        android:paddingTop="48dp"
                        android:paddingBottom="32dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_bias="0.75">



                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="sans-serif-black"
                                android:lineHeight="46sp"
                                android:text="IT'S TIME TO\nUNLEASH YOUR\nCREATIVITY."
                                android:textAllCaps="true"
                                android:textColor="#FFFFFF"
                                android:textSize="40sp"
                                android:letterSpacing="0.15" />

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btnHeroMenu"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="20dp"
                                app:cardBackgroundColor="#1A00D2D3"
                                app:cardCornerRadius="6dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="#4D00D2D3">
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="12dp"
                                    android:paddingVertical="6dp">
                                    <ImageView
                                        android:layout_width="10dp"
                                        android:layout_height="10dp"
                                        android:src="@drawable/ic_magic"
                                        app:tint="#00D2D3" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:fontFamily="monospace"
                                        android:letterSpacing="0.1"
                                        android:text="Pro Version"
                                        android:textColor="#00D2D3"
                                        android:textSize="9sp" />
                                    <TextView
                                        android:paddingStart="6dp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="monospace"
                                        android:letterSpacing="0.2"
                                        android:text="V4.0"
                                        android:textColor="#00D2D3"
                                        android:textSize="10sp"
                                        android:alpha="0.8"/>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_gravity="bottom"
                        android:background="@color/white_10" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="-30dp"
                    android:paddingHorizontal="24dp"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnNavFavorites"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#F20D0D0D"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="20dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_heart"
                                app:tint="#00D2D3"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FAVORITES"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:letterSpacing="0.05"
                                android:fontFamily="sans-serif-black"
                                android:layout_marginStart="10dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnNavMyProjects"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#F20D0D0D"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/white_10">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="20dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_folder"
                                app:tint="#00D2D3"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PROJECTS"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:letterSpacing="0.05"
                                android:fontFamily="sans-serif-black"
                                android:layout_marginStart="10dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:paddingHorizontal="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/StealthLabel"
                        android:letterSpacing="0.2"
                        android:text="Recent Projects"
                        android:textSize="10sp"
                        android:layout_centerVertical="true"/>
                    <TextView
                        android:id="@+id/btnResumeProject"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resume Last Project"
                        android:textColor="#00D2D3"
                        android:textAllCaps="true"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="2dp"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_tag_glass"/>
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentProjects"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:clipToPadding="false"
                    android:layout_marginTop="16dp"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="false"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEmptyRecent"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/white_05"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/white_10"
                    android:visibility="gone">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_video_camera"
                            app:tint="#00D2D3"
                            android:alpha="0.2"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No Active Sequences"
                            android:textColor="@color/white_30"
                            android:fontFamily="monospace"
                            android:textSize="11sp"
                            android:layout_marginStart="16dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingHorizontal="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/StealthLabel"
                        android:text="Learning Center"
                        android:letterSpacing="0.2"
                        android:textSize="10sp"
                        android:layout_centerVertical="true"/>
                <TextView
                    android:id="@+id/btnViewAllTutorials"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View More Tutorials"
                    android:textColor="#00D2D3"
                    android:textSize="10dp"
                    android:textAllCaps="true"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="2dp"
                    android:fontFamily="monospace"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_tag_glass"/>
                </RelativeLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTutorials"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:paddingHorizontal="16dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:paddingHorizontal="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/StealthLabel"
                        android:text="Trending Assets"
                        android:textSize="10sp"
                        android:letterSpacing="0.2"
                        android:layout_centerVertical="true"/>
                    <TextView
                        android:id="@+id/btnViewAllAssets" android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Open Marketplace"
                        android:textColor="#00D2D3"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="2dp"
                        android:textSize="8sp"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_tag_glass"/>
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTrendingAssets"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:paddingHorizontal="16dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_asset_card"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnMenuHome"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="48dp"
            android:layout_gravity="top|start"
            app:cardBackgroundColor="@color/white_05"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/white_10">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/ic_menu"
                app:tint="#00D2D3"/>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fabNewProject"
            style="@style/FabNeonStyle"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cornerRadius="8dp"
            android:layout_gravity="end|bottom"
            android:text="CREATE"
            android:textSize="13sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-black"
            tools:ignore="ExtraText"
            app:icon="@drawable/ic_add_bold"
            app:iconPadding="10dp"
            app:elevation="22dp"
            app:rippleColor="#3300D2D3"/>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:cardBackgroundColor="#F2000000"
        app:cardElevation="0dp"
        android:visibility="invisible"
        app:strokeWidth="1dp"
        app:strokeColor="@color/white_10">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <include layout="@layout/nav_header_main" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_line_glow_cyan"
                android:alpha="0.3"/>

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:background="@color/bg_deep_black">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="24dp"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WORKSPACE"
                        android:textColor="#00D2D3"
                        android:textSize="12sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="16dp"
                        android:layout_marginStart="12dp"/>

                    <LinearLayout
                        android:id="@+id/navBtnNewProject"
                        style="@style/NavDrawerItemStealth">
                        <ImageView
                            style="@style/NavIconStealth"
                            android:src="@drawable/ic_add" />
                        <TextView
                            style="@style/NavTextStealth"
                            android:text="Create Project"
 />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/navBtnFavorites"
                        style="@style/NavDrawerItemStealth">
                        <ImageView
                            style="@style/NavIconStealth"
                            android:src="@drawable/ic_heart" />
                        <TextView
                            style="@style/NavTextStealth"
                            android:text="FAVORITES" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/navBtnProjects"
                        style="@style/NavDrawerItemStealth">
                        <ImageView
                            style="@style/NavIconStealth"
                            android:src="@drawable/ic_folder" />
                        <TextView
                            style="@style/NavTextStealth"
                            android:text="Project Manager"
 />
                    </LinearLayout>



                    <View
                        android:layout_width="match_parent"
                        android:layout_height="32dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ARCHIVE"
                        android:textColor="#00D2D3"
                        android:textSize="12sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="16dp"
                        android:layout_marginStart="12dp"/>
                    <LinearLayout
                        android:id="@+id/navBtnMarketplace"
                        style="@style/NavDrawerItemStealth">
                        <ImageView
                            style="@style/NavIconStealth"
                            android:src="@drawable/ic_hub" />
                        <TextView
                            style="@style/NavTextStealth"
                            android:text="Assets Hub"
 />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/navBtnTutorials"
                        style="@style/NavDrawerItemStealth">
                        <ImageView
                            style="@style/NavIconStealth"
                            android:src="@drawable/ic_play" />
                        <TextView
                            style="@style/NavTextStealth"
                            android:text="Documentation" />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/navBtnHelp"
                        style="@style/NavDrawerItemStealth">
                        <ImageView
                            style="@style/NavIconStealth"
                            android:src="@drawable/ic_help"
                            app:tint="#FFFFFF" /> <TextView
                        style="@style/NavTextStealth"
                        android:text="Help &amp; Support" />
                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/white_05"
                        android:layout_marginVertical="12dp"/>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UTILITIES"
                        android:textColor="#00D2D3"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.2"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="12dp"
                        android:layout_marginStart="12dp"/>
                    <LinearLayout
                        android:id="@+id/navBtnAppInfo"
                        style="@style/NavDrawerItemStealth">
                        <ImageView
                            style="@style/NavIconStealth"
                            android:src="@drawable/ic_menu"
                            app:tint="#FFFFFF" />
                        <TextView
                            style="@style/NavTextStealth"
                            android:text="STUDIO_V4 INFO" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutNavSettings"
                        style="@style/NavDrawerItemStealth">
                        <ImageView
                            style="@style/NavIconStealth"
                            android:src="@drawable/ic_settings"
                            app:tint="@color/red_400"/>
                        <TextView
                            style="@style/NavTextStealth"
                            android:textColor="@color/red_400"
                            android:text="System Settings"
 />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/navBtnUpgrade"
                        style="@style/NavDrawerItemStealth">
                        <ImageView
                            style="@style/NavIconStealth"
                            android:src="@drawable/ic_crown"
                            app:tint="#00D2D3"/>
                        <TextView
                            style="@style/NavTextStealth"
                            android:textColor="#00D2D3"
                            android:alpha="0.6"
                            android:text="Premium Upgrade"
                            />
                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.drawerlayout.widget.DrawerLayout>