<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:openDrawer="end">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">


        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/toolbarTimeline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            app:elevation="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnBackContainer"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="16dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:src="@drawable/ic_back"
                        app:tint="?attr/colorSecondary" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvToolbarTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1"
                    android:text="TIMELINE EDITOR"
                    android:textAllCaps="true"
                    android:textColor="@color/brand_accent"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    app:layout_constraintEnd_toStartOf="@id/btnUndoContainer"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btnBackContainer"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/btnUndoContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintEnd_toStartOf="@id/btnRedoContainer"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <ImageView
                        android:id="@+id/btnUndo"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_undo"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnRedoContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintEnd_toStartOf="@id/btnSettingsContainer"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <ImageView
                        android:id="@+id/btnRedo"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_redo"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnSettingsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintEnd_toStartOf="@id/btnInfoContainer"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <ImageView
                        android:id="@+id/btnSettings"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_settings"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnInfoContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintEnd_toStartOf="@id/btnSaveContainer"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <ImageView
                        android:id="@+id/btnInfo"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_info"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnSaveContainer"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginEnd="16dp"
                        app:cardBackgroundColor="?attr/colorSecondaryContainer"
                        app:cardCornerRadius="10dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="?attr/colorSecondary"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <ImageView
                            android:id="@+id/btnSave"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            android:src="@drawable/ic_save"
                            app:tint="?attr/colorSecondary" />
                    </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutlineVariant" />
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Main content area for timeline preview -->
        <include
            android:id="@+id/editorPreview"
            layout="@layout/view_editor_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:src="@drawable/ic_plus"
            app:tint="?attr/colorOnPrimary"
            app:backgroundTint="@color/brand_accent" />

        <LinearLayout
            android:id="@+id/fabActionPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@drawable/bg_fab_panel"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="84dp"
            android:visibility="gone"
            android:elevation="10dp"
            android:clipChildren="false"
            android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/fabTier1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                    android:id="@+id/fabAddOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overlay"
                    app:icon="@drawable/ic_plus"
                    app:iconTint="#00D2D3"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#CC121212"
                    app:strokeColor="#3300D2D3"/>

                <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                    android:id="@+id/fabAddAppend"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Append"
                    app:icon="@drawable/ic_plus"
                    app:iconTint="#00D2D3"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#CC121212"
                    app:strokeColor="#3300D2D3"/>
                </LinearLayout>
            <View
                android:id="@+id/fabDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#22FFFFFF"
                android:layout_marginVertical="10dp"
                android:visibility="gone"/>

            <GridLayout
                android:id="@+id/fabTier2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:useDefaultMargins="true"
                android:visibility="gone">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnFabBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_back"
                    app:fabSize="mini"
                    app:tint="#00D2D3"
                    app:backgroundTint="#CC121212"
                    android:layout_margin="4dp"/>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnTypeGif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_gif"
                    app:fabSize="mini"
                    app:tint="#00D2D3"
                    app:backgroundTint="#CC121212"
                    android:layout_margin="4dp"/>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnTypeEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_emoji"
                    app:fabSize="mini"
                    app:tint="#00D2D3"
                    app:backgroundTint="#CC121212"
                    android:layout_margin="4dp"/>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnTypeSticker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_sticker"
                    app:fabSize="mini"
                    app:tint="#00D2D3"
                    app:backgroundTint="#CC121212"
                    android:layout_margin="4dp"/>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnTypeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_text"
                    app:fabSize="mini"
                    app:tint="#00D2D3"
                    app:backgroundTint="#CC121212"
                    android:layout_margin="4dp"/>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnTypeAudio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_music"
                    app:fabSize="mini"
                    app:tint="#00D2D3"
                    app:backgroundTint="#CC121212"
                    android:layout_margin="4dp"/>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnTypeImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_image"
                    app:fabSize="mini"
                    app:tint="#00D2D3"
                    app:backgroundTint="#CC121212"
                    android:layout_margin="4dp"/>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnTypeMedia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_video_camera"
                    app:fabSize="mini"
                    app:tint="#00D2D3"
                    app:backgroundTint="#CC121212"
                    android:layout_margin="4dp"/>
            </GridLayout>

        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- SIDEBAR DRAWER -->

</androidx.drawerlayout.widget.DrawerLayout>