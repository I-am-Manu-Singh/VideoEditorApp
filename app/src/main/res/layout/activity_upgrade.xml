<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_black">

    <!-- YOUR TOP BAR (unchanged) -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBackContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="@color/brand_accent" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Premium Upgrade"
                android:textColor="@color/brand_accent"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                app:layout_constraintStart_toEndOf="@id/btnBackContainer"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        android:overScrollMode="never"
        android:paddingHorizontal="24dp"
        android:paddingBottom="40dp"
        android:background="@color/bg_deep_black">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:gravity="center"
                android:layout_height="wrap_content"
                android:text="License Center"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="sans-serif-black"/>

            <!-- CURRENT LICENSE -->

            <!-- PRO TOGGLE CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white_05"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/white_10"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="vertical">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="Standard"
                            android:textColor="@color/white_50"
                            android:textSize="9sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="Essentials"
                            android:textColor="@color/text_medium_emphasis"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/brand_accent_10"
                        app:cardCornerRadius="6dp"
                        app:strokeColor="@color/brand_accent_30">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp">

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/ic_magic"
                                app:tint="@color/brand_accent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.1"
                                android:text="Active Version"
                                android:textColor="@color/brand_accent"
                                android:textSize="9sp" />
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="• Precision Cut &amp; Trim\n• HD Output Engine\n• Adaptive Audio Sync\n• Stable Render Pipeline\n• Essential Templates Library  "
                        android:textColor="@color/white_70"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.5"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnUpgradePro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/card_pro_selector"
                app:strokeColor="@color/card_pro_stroke"
                app:cardCornerRadius="16dp"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_width="0dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Recommended"
                                android:textColor="@color/brand_accent"
                                android:textSize="10sp"
                                android:fontFamily="monospace"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Master License"
                                android:textColor="@color/text_medium_emphasis"
                                android:textSize="22sp"
                                android:fontFamily="sans-serif-black"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="$4.99"
                            android:layout_gravity="end"
                            android:textColor="@color/card_pro_text"
                            android:textSize="24sp"
                            android:fontFamily="monospace"/>
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardBackgroundColor="@color/brand_accent_10"
                                app:cardCornerRadius="6dp"
                                app:strokeColor="@color/brand_accent_30">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingHorizontal="6dp"
                                    android:paddingVertical="6dp">

                                    <TextView
                                        android:id="@+id/btnUpgradeProAction"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="monospace"
                                        android:letterSpacing="0.1"
                                        android:text="Activate Now"
                                        android:textColor="@color/brand_accent"
                                        android:textSize="9sp" />
                                </LinearLayout>

                            </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="• Everything in ESSENTIALS\n• No Watermarks in Exports\n• 4K UHD Export Ready\n• Priority Buffer Render\n• Full Template Registry"
                        android:textColor="@color/white_70"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.5"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STUDIO TOGGLE CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnUpgradeStudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:foreground="?attr/selectableItemBackground"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/card_studio_selector"
                app:strokeColor="@color/card_studio_stroke"
                app:cardCornerRadius="16dp"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_width="0dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lifetime Access"
                                android:textColor="@color/design_default_color_error"
                                android:textSize="10sp"
                                android:fontFamily="monospace"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Studio Suite"
                                android:textColor="@color/text_medium_emphasis"
                                android:textSize="22sp"
                                android:fontFamily="sans-serif-black"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:text="$9.99"
                                android:layout_gravity="end"
                                android:textColor="@color/card_pro_text"
                                android:textSize="24sp"
                                android:fontFamily="monospace"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#26FF3A3A"
                app:cardCornerRadius="6dp"
                app:strokeColor="#4DFF3A3A">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="6dp">

                    <TextView
                        android:id="@+id/btnUpgradeStudioAction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Activate Now"
                        android:textColor="#FF3A3A"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.1"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="• Everything in MASTER License\n• Master Pro Features\n• Cloud Asset Sync Active\n• Enterprise Support Hub\n• Team Collective Suite"
                        android:textColor="@color/white_70"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.5"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvRestorePurchase"
                android:layout_width="match_parent"
                android:gravity="center"
                android:layout_height="wrap_content"
                android:text="Restore your License"
                android:textColor="@color/brand_accent"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:fontFamily="monospace"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>