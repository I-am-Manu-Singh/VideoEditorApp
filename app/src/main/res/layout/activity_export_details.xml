<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_black">


    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        tools:ignore="MissingConstraints">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBackContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="@color/brand_accent" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Export Details"
                android:textColor="@color/brand_accent"
                android:fontFamily="sans-serif-black"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.3"
                android:shadowColor="#40000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                app:layout_constraintStart_toEndOf="@id/btnBackContainer"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:gravity="center_horizontal">

            <!-- 🍏 SUCCESS BADGE -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSuccessBadge"
                android:layout_width="96dp"
                android:layout_height="96dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="48dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/brand_accent">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp"
                    android:src="@drawable/ic_check"
                    app:tint="@color/brand_accent" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Project Masterpiece"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="sans-serif-black"/>

            <TextView
                android:id="@+id/tvMetaInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="4K Cinema • 24MB • 00:15"
                android:textColor="@color/brand_accent"
                android:textStyle="bold"
                android:textSize="14sp"
                android:fontFamily="monospace"/>



            <!-- 🍏 THE GLASS PLAYER CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/previewContainer"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/bg_dark_surface"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_20">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.media3.ui.PlayerView
                        android:id="@+id/playerViewPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:use_controller="false"
                        app:resize_mode="fit"
                        android:background="@android:color/black" />

                    <ImageView
                        android:id="@+id/ivExportPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:alpha="1.0"
                        android:background="@android:color/black"/>

                    <!-- Play Overlay -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgPlayOverlay"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_play"
                        android:padding="20dp"
                        android:background="@color/white_20"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        app:tint="@color/text_primary"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Blur Bottom Bar -->
                    <LinearLayout
                        android:id="@+id/playerControls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:background="#99000000"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <SeekBar
                            android:id="@+id/seekVideoProgress"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:progressTint="@color/brand_accent"
                            android:thumbTint="@color/brand_accent" />

                        <TextView
                            android:id="@+id/tvCurrentTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:layout_marginStart="8dp"
                            android:fontFamily="monospace"/>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🍏 EXPORTING PROGRESS PANEL -->
            <LinearLayout
                android:id="@+id/layoutExportingProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RENDERING_ENGINE_ACTIVE"
                    android:textColor="@color/brand_accent"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.4"
                    android:textSize="10sp"
                    android:layout_marginBottom="16dp"/>

                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progressCircular"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        app:indicatorSize="120dp"
                        app:trackThickness="12dp"
                        app:indicatorColor="@color/brand_accent"
                        app:trackColor="@color/white_10"
                        android:progress="0"
                        app:trackCornerRadius="6dp"/>

                    <TextView
                        android:id="@+id/tvProgressPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="0%"
                        android:textColor="@color/text_primary"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-black"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvTimeRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ESTIMATING_TIME..."
                    android:textColor="@color/white_50"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/logContainer"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/bg_dark_surface"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/white_05"
                    android:layout_marginBottom="16dp">

                    <ScrollView
                        android:id="@+id/logScrollView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp">
                        <TextView
                            android:id="@+id/tvEngineLogs"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white_50"
                            android:textSize="10sp"
                            android:fontFamily="monospace"
                            android:text="[SYSTEM] Initializing render engine..."/>
                    </ScrollView>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelExport"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="CANCEL_EXPORT"
                    android:textColor="@color/status_error"
                    android:fontFamily="sans-serif-black"
                    app:cornerRadius="16dp"
                    android:backgroundTint="@color/white_10" />
            </LinearLayout>

            <!-- 🍏 TECHNICAL SPECS PANEL -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTechSpecs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TECHNICAL SPECS"
                        android:textSize="11sp"
                        android:textColor="@color/brand_accent"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        app:dividerColor="@color/white_10"
                        android:layout_marginBottom="16dp"/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FORMAT"
                                android:textColor="@color/white_50"
                                android:textSize="10sp"/>
                            <TextView
                                android:id="@+id/tvFormat"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="H.264 / AVC"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="serif-monospace"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BITRATE"
                                android:textColor="@color/white_50"
                                android:textSize="10sp"/>
                            <TextView
                                android:id="@+id/tvBitrate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4500 kbps"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="serif-monospace"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginTop="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RESOLUTION"
                                android:textColor="@color/white_50"
                                android:textSize="10sp"/>
                            <TextView
                                android:id="@+id/tvResDetail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3840 x 2160"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="serif-monospace"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginTop="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FILE SIZE"
                                android:textColor="@color/white_50"
                                android:textSize="10sp"/>
                            <TextView
                                android:id="@+id/tvSizeDetail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="45.8 MB"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="serif-monospace"/>
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🍏 UNIFIED SHARING & QUICK ACTIONS -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUnifiedActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                android:visibility="gone">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:gravity="center_vertical">

                        <include layout="@layout/item_share_icon" android:id="@+id/shareTikTok"/>
                        <include layout="@layout/item_share_icon" android:id="@+id/shareInstagram"/>
                        <include layout="@layout/item_share_icon" android:id="@+id/shareWhatsApp"/>
                        <include layout="@layout/item_share_icon" android:id="@+id/shareYouTube"/>
                        
                        <!-- Divider line -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="@color/white_10"/>
                            
                        <include layout="@layout/item_share_icon" android:id="@+id/actionGallery"/>
                        <include layout="@layout/item_share_icon" android:id="@+id/actionDelete"/>
                    </LinearLayout>
                </HorizontalScrollView>
            </com.google.android.material.card.MaterialCardView>


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
