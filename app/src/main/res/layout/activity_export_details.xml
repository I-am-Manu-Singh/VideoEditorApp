<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_black">


    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        tools:ignore="MissingConstraints">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBackContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="#00D2D3" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Export Details"
                android:textColor="#00D2D3"
                android:fontFamily="sans-serif-black"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.3"
                android:shadowColor="#40000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                app:layout_constraintStart_toEndOf="@id/btnBackContainer"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:gravity="center_horizontal">

            <!-- 🍏 SUCCESS BADGE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="96dp"
                android:layout_height="96dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="48dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/brand_accent">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp"
                    android:src="@drawable/ic_check"
                    app:tint="@color/brand_accent" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Project Masterpiece"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="sans-serif-black"/>

            <TextView
                android:id="@+id/tvMetaInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="4K Cinema • 24MB • 00:15"
                android:textColor="@color/brand_accent"
                android:textStyle="bold"
                android:textSize="14sp"
                android:fontFamily="monospace"/>

            <!-- 🍏 THE GLASS PLAYER CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/previewContainer"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/bg_dark_surface"
                app:cardCornerRadius="32dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_20">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.media3.ui.PlayerView
                        android:id="@+id/playerViewPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:use_controller="false"
                        app:resize_mode="fit"
                        android:background="@android:color/black" />

                    <!-- Play Overlay -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgPlayOverlay"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_play"
                        android:padding="20dp"
                        android:background="@color/white_20"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        app:tint="@color/white"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Blur Bottom Bar -->
                    <LinearLayout
                        android:id="@+id/playerControls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:background="#99000000"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <SeekBar
                            android:id="@+id/seekVideoProgress"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:progressTint="@color/brand_accent"
                            android:thumbTint="@color/brand_accent" />

                        <TextView
                            android:id="@+id/tvCurrentTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:layout_marginStart="8dp"
                            android:fontFamily="monospace"/>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🍏 TECHNICAL SPECS PANEL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TECHNICAL SPECS"
                        android:textSize="11sp"
                        android:textColor="@color/brand_accent"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        app:dividerColor="@color/white_10"
                        android:layout_marginBottom="16dp"/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FORMAT"
                                android:textColor="@color/white_50"
                                android:textSize="10sp"/>
                            <TextView
                                android:id="@+id/tvFormat"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="H.264 / AVC"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="serif-monospace"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BITRATE"
                                android:textColor="@color/white_50"
                                android:textSize="10sp"/>
                            <TextView
                                android:id="@+id/tvBitrate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4500 kbps"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="serif-monospace"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginTop="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RESOLUTION"
                                android:textColor="@color/white_50"
                                android:textSize="10sp"/>
                            <TextView
                                android:id="@+id/tvResDetail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3840 x 2160"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="serif-monospace"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginTop="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FILE SIZE"
                                android:textColor="@color/white_50"
                                android:textSize="10sp"/>
                            <TextView
                                android:id="@+id/tvSizeDetail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="45.8 MB"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="serif-monospace"/>
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 🍏 QUICK ACTIONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:weightSum="10">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShare"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="4"
                    android:layout_marginEnd="12dp"
                    android:text="SHARE"
                    android:textStyle="bold"
                    app:icon="@android:drawable/ic_menu_share"
                    app:iconTint="@color/white"
                    app:cornerRadius="20dp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/white_10" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenExternal"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="4"
                    android:layout_marginEnd="12dp"
                    android:text="GALLERY"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_play"
                    app:iconTint="@color/white"
                    app:cornerRadius="20dp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/white_10" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDel"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="2"
                    app:icon="@drawable/ic_delete"
                    app:iconTint="@color/status_error"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:cornerRadius="20dp"
                    android:backgroundTint="@color/white_10" />
            </LinearLayout>


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
