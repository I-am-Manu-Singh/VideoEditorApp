<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/previewContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="?attr/colorSurface"
        app:layout_constraintBottom_toTopOf="@id/previewSplitGuideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:resize_mode="fit"
            app:use_controller="false" />

        <!-- Empty State Placeholder -->
        <LinearLayout
            android:id="@+id/layoutEmptyPreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:visibility="visible">
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_video_camera"
                app:tint="?attr/colorSecondary"
                android:alpha="0.2" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap + to start your masterpiece"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.6"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/interactiveOverlayLayer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="@id/playerView"
            app:layout_constraintEnd_toEndOf="@id/playerView"
            app:layout_constraintStart_toStartOf="@id/playerView"
            app:layout_constraintTop_toTopOf="@id/playerView">

            <com.example.videoeditorapp.ui.preview.OverlayManipulationView
                android:id="@+id/overlayManipulationView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />
        </FrameLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:indeterminateTint="?attr/colorSecondary" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/previewSplitGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.45" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/landscapeSplitGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <View
        android:id="@+id/previewResizeHandle"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:background="@drawable/bg_resize_handle_ribs"
        android:alpha="1"
        app:layout_constraintTop_toBottomOf="@id/previewSplitGuideline" />
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/playbackControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/colorSurface"
        app:layout_constraintTop_toBottomOf="@id/previewResizeHandle">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp">

            <!-- Time -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTimeCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textAllCaps="true"
                    android:paddingStart="8dp"
                    android:letterSpacing="0.2"
                    android:text="00:00:00"
                    android:textColor="?attr/colorSecondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" / "
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp" />


                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="roboto"
                    android:textAllCaps="true"
                    android:letterSpacing="0.2"
                    android:text="00:00:00"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:alpha="0.7"
                    android:textSize="14sp" />
            </LinearLayout>
            </LinearLayout>
            <!-- Center HUB -->
            <LinearLayout
                android:id="@+id/playbackHub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- PREV (New Card) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnPrevClip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="46dp"
                    app:cardBackgroundColor="@color/white_20"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/white_10">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="6dp"
                        android:src="@drawable/ic_skip_previous"
                        app:tint="?attr/colorOnSurface" />
                </com.google.android.material.card.MaterialCardView>

                <!-- FRAME BACK -->
                <ImageView
                    android:id="@+id/btnFrameBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_chevron_left"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:tint="?attr/colorOnSurface"
                    android:alpha="0.6" />

                <!-- PLAY/PAUSE (Existing Premium Button) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginHorizontal="4dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="@color/brand_accent"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="52dp"
                    app:cardElevation="8dp"
                    android:foreground="@drawable/stroke_top_bottom">

                    <ImageView
                        android:id="@+id/btnPlayPause"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="6dp"
                        android:src="@drawable/ic_play"
                        app:tint="@color/selector_play_button_tint" />
                </com.google.android.material.card.MaterialCardView>

                <!-- FRAME FWD -->
                <ImageView
                    android:id="@+id/btnFrameFwd"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_chevron_right"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:tint="?attr/colorOnSurface"
                    android:alpha="0.6" />

                <!-- NEXT (New Card) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnNextClip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="46dp"
                    app:cardBackgroundColor="@color/white_20"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/white_10">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="6dp"
                        android:src="@drawable/ic_skip_next"
                        app:tint="?attr/colorOnSurface" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- STOP -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnStop"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="#33FF5252"
                app:cardBackgroundColor="#1AFF5252">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_stop"
                    app:tint="#FF5252" />
            </com.google.android.material.card.MaterialCardView>

        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>


    <HorizontalScrollView
        android:id="@+id/timelineToolbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="?attr/colorSurface"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/playbackControls">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="4dp">

            <!-- SELECT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSelect"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="10dp"
                app:cardElevation="8dp"
                android:foreground="@drawable/stroke_top_bottom">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_cursor"
                        app:tint="?attr/colorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SELECT"
                        android:textColor="?attr/colorOnSurface"
                        android:letterSpacing="0.2"
                        android:textSize="8sp"
                        android:fontFamily="sans-serif-black"
                        android:alpha="0.8"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MAGNET -->


            <!-- SPLIT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSplit"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:cardBackgroundColor="@color/white_05">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_content_cut"
                        app:tint="?attr/colorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SPLIT"
                        android:textColor="?attr/colorOnSurface"

                        android:letterSpacing="0.2"
                        android:textSize="8sp"
                        android:fontFamily="sans-serif-black"
                        android:alpha="0.8"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TRIM -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnTrim"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:cardBackgroundColor="@color/white_05">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_open_in_full"
                        app:tint="?attr/colorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TRIM"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="8sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-black"
                        android:alpha="0.8"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SPEED -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSpeed"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:cardBackgroundColor="@color/white_05">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:id="@+id/viewSpeedFill"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_gravity="bottom"
                        android:background="@color/brand_accent"
                        android:alpha="0.2" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_speed"
                            app:tint="?attr/colorSecondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SPEED"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="8sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-black"
                            android:alpha="0.8"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- VOLUME -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnVolume"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:cardBackgroundColor="@color/white_05">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <View
                        android:id="@+id/viewVolumeFill"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_gravity="bottom"
                        android:background="@color/brand_secondary"
                        android:alpha="0.2" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_volume_up"
                            app:tint="?attr/colorSecondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VOLUME"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="8sp"
                            android:letterSpacing="0.2"
                            android:fontFamily="sans-serif-black"
                            android:alpha="0.8"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- COPY (Renamed from DUPLICATE) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnCopyClip"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:cardBackgroundColor="@color/white_05">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_copy"
                        app:tint="?attr/colorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="COPY"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="8sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-black"
                        android:alpha="0.8"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PASTE -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnPasteClip"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:cardBackgroundColor="@color/white_05"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_paste"
                        app:tint="?attr/colorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PASTE"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="8sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-black"
                        android:alpha="0.8"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>



            <!-- CROP (Video/Image) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnCropClip"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:cardBackgroundColor="@color/white_05">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_crop"
                        app:tint="?attr/colorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CROP"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="8sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-black"
                        android:alpha="0.8"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>




            <!-- FRONT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnMoveToFront"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:cardBackgroundColor="@color/white_05">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_layers"
                        app:tint="?attr/colorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FRONT"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="8sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-black"
                        android:alpha="0.8"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BACK -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnMoveToBack"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:cardBackgroundColor="@color/white_05">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_layers"
                        android:rotation="180"
                        app:tint="?attr/colorSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BACK"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="8sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-black"
                        android:alpha="0.8"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- DELETE -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnDeleteClip"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:cardBackgroundColor="@color/white_05">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iconDelete"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_delete"
                        app:tint="?attr/colorSecondary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DELETE"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="8sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-black"
                        android:alpha="0.8"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </HorizontalScrollView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/timelineVerticalScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="?attr/colorSurface"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/bottomNavWrapper"
        app:layout_constraintTop_toBottomOf="@id/timelineToolbar">

        <com.example.videoeditorapp.ui.timeline.TimelineView
            android:id="@+id/timelineView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="120dp"
            android:clipToPadding="false" />
    </androidx.core.widget.NestedScrollView>
    <LinearLayout
        android:id="@+id/bottomNavWrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_bar_rounded"
        android:backgroundTint="?attr/colorSurfaceVariant"
        android:elevation="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <HorizontalScrollView
            android:id="@+id/bottomNavTabs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:background="@android:color/transparent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="88dp"
                android:paddingVertical="12dp"
                android:background="@android:color/transparent"
                android:clipToPadding="false">

                <!-- EDIT / PROPERTIES -->
                <LinearLayout
                    android:id="@+id/tabEdit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/CinematicNavTab"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_nav_tab">

                    <ImageView
                        style="@style/CinematicNavIcon"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/nav_icon_tint" />

                    <TextView
                        style="@style/CinematicNavLabel"
                        android:text="ADJUST"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textColor="@color/nav_label_tint" />
                </LinearLayout>


                <!-- EFFECTS -->
                <LinearLayout
                    android:id="@+id/tabEffects"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/CinematicNavTab"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_nav_tab">

                    <ImageView
                        style="@style/CinematicNavIcon"
                        android:src="@drawable/ic_magic"
                        app:tint="@color/nav_icon_tint" />

                    <TextView
                        style="@style/CinematicNavLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:text="EFFECTS"
                        android:textColor="@color/nav_label_tint" />
                </LinearLayout>

                <!-- FILTERS -->
                <LinearLayout
                    android:id="@+id/tabFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/CinematicNavTab"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_nav_tab">

                    <ImageView
                        style="@style/CinematicNavIcon"
                        android:src="@drawable/ic_filter"
                        app:tint="@color/nav_icon_tint" />

                    <TextView
                        style="@style/CinematicNavLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FILTERS"
                        android:textStyle="bold"
                        android:textColor="@color/nav_label_tint" />
                </LinearLayout>

                <!-- REVERSE -->
                <LinearLayout
                    android:id="@+id/tabReverse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/CinematicNavTab"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_nav_tab">

                    <ImageView
                        style="@style/CinematicNavIcon"
                        android:src="@drawable/ic_reverse"
                        app:tint="@color/nav_icon_tint" />

                    <TextView
                        style="@style/CinematicNavLabel"
                        android:text="REVERSE"
                        android:textStyle="bold"
                        android:textColor="@color/nav_label_tint" />
                </LinearLayout>

                <!-- OPACITY -->
                <LinearLayout
                    android:id="@+id/tabOpacity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/CinematicNavTab"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_nav_tab">

                    <ImageView
                        style="@style/CinematicNavIcon"
                        android:src="@drawable/ic_opacity"
                        app:tint="@color/nav_icon_tint" />

                    <TextView
                        style="@style/CinematicNavLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OPACITY"
                        android:textColor="@color/nav_label_tint" />
                </LinearLayout>

                <!-- FADE -->
                <LinearLayout
                    android:id="@+id/tabFade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/CinematicNavTab"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_nav_tab">

                    <ImageView
                        style="@style/CinematicNavIcon"
                        android:src="@drawable/ic_fade"
                        app:tint="@color/nav_icon_tint" />

                    <TextView
                        style="@style/CinematicNavLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" FADE "
                        android:textColor="@color/nav_label_tint" />
                </LinearLayout>

                <!-- HUB / ASSETS -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tabHub"
                    style="@style/CinematicNavTab"
                    android:background="@drawable/bg_nav_tab">

                    <ImageView
                        style="@style/CinematicNavIcon"
                        android:src="@drawable/ic_hub"
                        app:tint="@color/nav_icon_tint" />

                    <TextView
                        style="@style/CinematicNavLabel"
                        android:text="  HUB  "
                        android:textColor="@color/nav_label_tint" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
</layout>