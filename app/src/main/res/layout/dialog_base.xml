<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/dialog_background"
    app:shapeAppearanceOverlay="@style/DialogRoundedCorners"
    app:strokeWidth="1dp"
    app:strokeColor="@color/brand_accent_25"
    app:cardElevation="0dp"
    android:clipToOutline="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:id="@+id/dialogHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/ivDialogIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_info"
                app:tint="@color/brand_accent"
                android:visibility="gone"/>

            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:background="@color/brand_accent"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SYSTEM MESSAGE"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white_50"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/dialogButtonContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSecondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CANCEL"
                android:textColor="#66FFFFFF"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.05"
                app:strokeColor="@color/white_20"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="6dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrimary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXECUTE"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:backgroundTint="@color/brand_accent"
                android:layout_marginStart="12dp"
                app:cornerRadius="6dp"
                app:rippleColor="#40000000"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>