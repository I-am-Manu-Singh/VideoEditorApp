<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white_05"
    app:strokeWidth="1dp"
    app:strokeColor="@color/white_10">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconWrapper"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/bg_dark_elevated"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/white_05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivProjectIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@drawable/ic_layers"
                app:tint="#00D2D3"/>
        </com.google.android.material.card.MaterialCardView>

        <ImageButton
            android:id="@+id/btnFavoriteProject"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_heart"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/white_30"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvProjectName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            tools:text="Cinematic Edit - V4"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:textColor="#FFFFFF"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/iconWrapper"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnFavoriteProject"/>

        <TextView
            android:id="@+id/tvLastModified"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            tools:text="Modified 2m ago"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:textColor="@color/white_50"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toStartOf="@id/tvProjectName"
            app:layout_constraintTop_toBottomOf="@id/tvProjectName"/>

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tag_glass"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:fontFamily="monospace"
            android:textColor="#00D2D3"
            android:textSize="9sp"
            tools:text="00:45:12"
            app:layout_constraintStart_toStartOf="@id/tvProjectName"
            app:layout_constraintTop_toBottomOf="@id/tvLastModified"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>