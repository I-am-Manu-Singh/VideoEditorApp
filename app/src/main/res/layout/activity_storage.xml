<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_black">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBackContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="#00D2D3" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Resource Monitor"
                android:textColor="#00D2D3"
                android:fontFamily="sans-serif-black"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.3"
                app:layout_constraintStart_toEndOf="@id/btnBackContainer"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="20dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white_05"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL APP FOOTPRINT"
                        android:textColor="#00D2D3"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/tvTotalSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="145.2 MB"
                        android:textColor="#FFFFFF"
                        android:textSize="38sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/progressBarStorage"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="24dp"
                        android:progress="45"
                        android:progressDrawable="@drawable/bg_progress_cyan_stealth" />

                    <TextView
                        android:id="@+id/tvFreeSpace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="DISK STATUS: 24 GB AVAILABLE"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:textColor="@color/white_30"
                        android:letterSpacing="0.1"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/StealthLabel"
                android:text="STORAGE ALLOCATION"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white_05"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp"> <include
                    android:id="@+id/itemProjects"
                    layout="@layout/item_storage_category"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                    <View style="@style/StealthDivider" />

                    <include
                        android:id="@+id/itemExports"
                        layout="@layout/item_storage_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <View style="@style/StealthDivider" />

                    <include
                        android:id="@+id/itemDownloads"
                        layout="@layout/item_storage_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <View style="@style/StealthDivider" />

                    <include
                        android:id="@+id/itemMedia"
                        layout="@layout/item_storage_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <View style="@style/StealthDivider" />

                    <include
                        android:id="@+id/itemCache"
                        layout="@layout/item_storage_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>