<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/dialog_background"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/white_10">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="28dp">

        <LinearLayout
            android:id="@+id/headerGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:layout_width="3dp"
                android:layout_height="16dp"
                android:background="@color/brand_accent" />

            <TextView
                android:id="@+id/dialogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:text="PROPERTY_ENGINE // ADJUST_VAL"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textAllCaps="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="monospace"
            android:letterSpacing="-0.05"
            android:text="50.00"
            android:textColor="@color/brand_accent"
            android:textSize="48sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerGroup" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDecrease"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:fontFamily="monospace"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="-"
            android:textColor="@color/brand_accent"
            android:textSize="22sp"
            app:cornerRadius="12dp"
            app:layout_constraintBottom_toBottomOf="@id/slider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/slider"
            app:strokeColor="@color/brand_accent_10"
            android:backgroundTint="@color/brand_accent_05" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="32dp"
            android:valueFrom="0"
            android:valueTo="100"
            app:haloColor="@color/brand_accent_10"
            app:layout_constraintEnd_toStartOf="@id/btnIncrease"
            app:layout_constraintStart_toEndOf="@id/btnDecrease"
            app:layout_constraintTop_toBottomOf="@id/tvValue"
            app:thumbColor="@color/brand_accent"
            app:trackColorActive="@color/brand_accent"
            app:trackColorInactive="@color/white_10"
            app:thumbRadius="10dp"
            app:trackHeight="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIncrease"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:fontFamily="monospace"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="+"
            android:textColor="@color/brand_accent"
            android:textSize="22sp"
            app:cornerRadius="12dp"
            app:layout_constraintBottom_toBottomOf="@id/slider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/slider"
            app:strokeColor="@color/brand_accent_10"
            android:backgroundTint="@color/brand_accent_05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="monospace"
            android:text="STATUS: CALIBRATED // PRECISION_MODE"
            android:textColor="@color/text_primary"
            android:textSize="8sp"
            android:alpha="0.3"
            android:letterSpacing="0.1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/slider" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>