<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_black">

    <FrameLayout
        android:id="@+id/previewContainer"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivTutorialCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/temp_cinematic" />

    </FrameLayout>

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBackContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                app:cardBackgroundColor="@color/bg_dark_surface"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="@color/brand_accent" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Instructional Guide"
                android:visibility="invisible"
                app:layout_constraintStart_toEndOf="@id/btnBackContainer"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:translationY="-48dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/previewContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_sheet_cinematic"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="40dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/chipLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/brand_accent_10"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="Level: Standard"
                    android:textColor="@color/brand_accent"
                    android:textSize="9sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvTutorialTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tutorial Title"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textAllCaps="true"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="16dp"/>

                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="@color/brand_accent"
                    android:layout_marginBottom="24dp"/>

                <TextView
                    android:id="@+id/tvTutorialContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Here is where the step-by-step tutorial content will go. It will explain how to achieve the effect or technique described in the title."
                    android:textColor="@color/white_70"
                    android:textSize="15sp"
                    android:lineHeight="24sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="40dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWatchVideo"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Watch Masterclass Video"
                    android:textColor="@color/color_on_accent"
                    app:icon="@drawable/ic_play"
                    app:iconTint="@color/color_on_accent"
                    app:iconGravity="textStart"
                    app:backgroundTint="@color/brand_accent"
                    app:cornerRadius="8dp"
                    android:textSize="13sp"
                    android:letterSpacing="0.05"
                    android:fontFamily="sans-serif-black"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:text="Verified Academy Module"
                    android:textColor="@color/white_20"
                    android:textSize="9sp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>