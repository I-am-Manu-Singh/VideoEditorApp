<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="#0A0A0A"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1AFFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Bottom Sheet Handle -->
        <View
            android:id="@+id/sheetHandle"
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            android:background="#33FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/headerIndicator"
            android:layout_width="3dp"
            android:layout_height="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="28dp"
            android:background="#00D2D3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:text="Edit Parameters"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textAllCaps="true"
            app:layout_constraintBottom_toBottomOf="@id/headerIndicator"
            app:layout_constraintEnd_toStartOf="@id/btnClose"
            app:layout_constraintStart_toEndOf="@id/headerIndicator"
            app:layout_constraintTop_toTopOf="@id/headerIndicator" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="20dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_close"
            app:layout_constraintBottom_toBottomOf="@id/headerIndicator"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/headerIndicator"
            app:tint="#4DFFFFFF" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:clipToPadding="false"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            app:layout_constraintTop_toBottomOf="@id/headerIndicator" />

        <LinearLayout
            android:id="@+id/containerSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            app:layout_constraintTop_toBottomOf="@id/rvOptions">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSliderLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:text="Adjustment Intensity"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tvSliderValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="0.0%"
                    android:textColor="#00D2D3"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Only Slider remains as per user request for precision -->
            <com.google.android.material.slider.Slider
                android:id="@+id/sliderControl"
                style="@style/StealthSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="0.5"
                android:valueFrom="0.0"
                android:valueTo="1.0"
                app:thumbRadius="10dp"
                app:trackHeight="4dp" />

            <!-- Hidden legacy controls -->
            <com.example.videoeditorapp.ui.editor.controls.WheelControlView
                android:id="@+id/wheelControl"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone" />

            <com.example.videoeditorapp.ui.editor.controls.CircularSliderView
                android:id="@+id/circularControl"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="32dp"
            android:layout_marginLeft="24dp"
            android:layout_marginRight="24dp"
            android:backgroundTint="#00D2D3"
            android:fontFamily="sans-serif-black"
            android:text="Apply Changes"
            android:textColor="#121212"
            android:textSize="13sp"
            android:letterSpacing="0.05"
            app:cornerRadius="12dp"
            app:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/containerSlider" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>