<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_black">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBackContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="#00D2D3" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Documentation"
                android:textColor="#00D2D3"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                app:layout_constraintStart_toEndOf="@id/btnBackContainer"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:background="@color/bg_deep_black"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:text="Editor Masterclass"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-black" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white_05"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="#00D2D3"
                            android:gravity="center"
                            android:text="01"
                            android:fontFamily="monospace"
                            android:textColor="@color/bg_deep_black"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Import &amp; Index"
                            android:textColor="#FFFFFF"
                            android:layout_marginStart="12dp"
                            android:textSize="13sp"
                            android:letterSpacing="0.05"
                            android:fontFamily="sans-serif-black"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Initialize your sequence. Load media assets from the system directory. Studio V4 scales 4K metadata pipelines automatically."
                        android:textColor="@color/white_50"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white_05"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="#00D2D3"
                            android:gravity="center"
                            android:text="02"
                            android:fontFamily="monospace"
                            android:textColor="@color/bg_deep_black"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Precision Timeline"
                            android:textColor="#FFFFFF"
                            android:layout_marginStart="12dp"
                            android:textSize="13sp"
                            android:letterSpacing="0.05"
                            android:fontFamily="sans-serif-black"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Engage multi-track scrub logic. Utilize frame-accurate trimming and pinch-to-zoom for detailed vector scrubbing."
                        android:textColor="@color/white_50"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white_05"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="#00D2D3"
                            android:gravity="center"
                            android:text="03"
                            android:fontFamily="monospace"
                            android:textColor="@color/bg_deep_black"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Visual FX Pipeline"
                            android:textColor="#FFFFFF"
                            android:layout_marginStart="12dp"
                            android:textSize="13sp"
                            android:letterSpacing="0.05"
                            android:fontFamily="sans-serif-black"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Inject cinematic LUTs and glitch layers. Orchestrate audio DSP mixing with real-time waveform visualization."
                        android:textColor="@color/white_50"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Academy Lectures"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:letterSpacing="0.05"
                    android:fontFamily="sans-serif-black"/>

                <TextView
                    android:id="@+id/btnViewAllArticles"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Browse Library"
                    android:textColor="#00D2D3"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:letterSpacing="0.1"/>
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMasterArticles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_article_list"/>

            <TextView
                style="@style/StealthLabel"
                android:text="Pro Workflow Tips"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_05">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. Hold clips for sequence re-allocation."
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2. Split at playhead for transition injection."
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="3. Force 4K export via Master Registry."
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGotIt"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="24dp"
                android:text="Start Editing"
                android:textColor="@color/bg_deep_black"
                android:backgroundTint="#00D2D3"
                app:cornerRadius="8dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="STUDIO_ACADEMY_V4 // HELP.STUDIO_ENGINE.COM"
                android:gravity="center"
                android:textColor="@color/white_20"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:textAllCaps="true"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>