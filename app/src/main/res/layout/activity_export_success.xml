<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_black">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_hero_gradient_final"
        android:alpha="0.2"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPreview"
        android:layout_width="0dp"
        android:layout_height="320dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="20dp"
        app:strokeWidth="2dp"
        app:strokeColor="@color/brand_accent"
        android:layout_margin="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/ivFinalThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/temp_cinematic"/>
            
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                app:tint="#CCFFFFFF"
                android:padding="8dp"
                android:background="@drawable/bg_round_glass"/>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvCongrats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MASTERPIECE_READY"
        android:textColor="@color/brand_accent"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.4"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/cardPreview"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvVideoInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4K / 60FPS • 42.5 MB"
        android:textColor="@color/white_50"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvCongrats"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/shareContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvVideoInfo">
        
        <include layout="@layout/item_share_icon" android:id="@+id/shareTikTok"/>
        <include layout="@layout/item_share_icon" android:id="@+id/shareInstagram"/>
        <include layout="@layout/item_share_icon" android:id="@+id/shareWhatsApp"/>
        <include layout="@layout/item_share_icon" android:id="@+id/shareYouTube"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDone"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="BACK_TO_STUDIO"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="40dp"
        app:cornerRadius="16dp"
        app:backgroundTint="@color/brand_accent"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-black"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
