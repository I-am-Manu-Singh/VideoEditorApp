<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_black">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBackContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                app:cardBackgroundColor="@color/bg_dark_elevated"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="@color/brand_accent" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="SYSTEM SETTINGS"
                android:textColor="@color/brand_accent"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                app:layout_constraintStart_toEndOf="@id/btnBackContainer"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:background="@color/bg_deep_black"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                style="@style/StealthLabel"
                android:text="PREFERENCES"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white_05"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INTERFACE THEME"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:fontFamily="sans-serif-black"/>

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/rgThemeSelection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeLight"
                            style="@style/StealthToggleBtn"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="LIGHT" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThemeDark"
                            style="@style/StealthToggleBtn"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="DARK" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/StealthLabel"
                android:text="MASTER OUTPUT PARAMETERS"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white_05"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">



                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/rgDefaultResolution"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDefault720"
                            style="@style/StealthToggleBtn"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="720P" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDefault1080"
                            style="@style/StealthToggleBtn"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="1080P" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDefault2K"
                            style="@style/StealthToggleBtn"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="2K" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDefault4K"
                            style="@style/StealthToggleBtn"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="4K" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDefaultOriginal"
                            style="@style/StealthToggleBtn"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="ORIG" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/rgDefaultAspect"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAspectOriginal"
                            style="@style/StealthToggleBtn"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="ORIG" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAspect11"
                            style="@style/StealthToggleBtn"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="1:1" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAspect169"
                            style="@style/StealthToggleBtn"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="16:9" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAspect916"
                            style="@style/StealthToggleBtn"
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:text="9:16" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/StealthLabel"
                android:text="ADVANCED"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white_05"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUTOSAVE INTERVAL"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"/>

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/rgAutoSave"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton android:id="@+id/btnAutoSave30s"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1"
                            android:text="30 secs" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnAutoSave1m"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1"
                            android:text="1 min" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnAutoSave2m"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1"
                            android:text="2 mins" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnAutoSaveOff"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1" android:text="OFF" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white_05"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VIDEO ENCODING QUALITY"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"/>

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/rgExportQuality"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton android:id="@+id/btnQualityLow"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1" android:text="LOW" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnQualityMedium"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1" android:text="MED" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnQualityHigh"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1" android:text="HIGH" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnQualityUltra"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1" android:text="ULTRA" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white_05"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VIDEO CODEC"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"/>

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/codecSelectionGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSettingsCodecH264"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1" android:text="H.264" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnSettingsCodecH265"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1" android:text="H.265 (HEVC)" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <TextView
                        android:id="@+id/tvCodecWarning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="H.265 provides better quality at smaller size but may not be supported on all devices."
                        android:textColor="@color/text_medium_emphasis"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:visibility="gone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white_05"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUDIO ENCODING QUALITY"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:fontFamily="monospace"/>

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/rgAudioQuality"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton android:id="@+id/btnAudio128"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1"
                            android:text="128kbps" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnAudio192"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1"
                            android:text="192kbps" />
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnAudio320"
                            android:layout_height="wrap_content" style="@style/StealthToggleBtn"
                            android:layout_width="0dp" android:layout_weight="1"
                            android:text="320kbps" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white_05"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HW ACCELERATION"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:fontFamily="sans-serif-black"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FORCE GPU RENDER ENGINE"
                            android:textColor="@color/text_medium_emphasis"
                            android:textSize="9sp"
                            android:layout_marginTop="4dp"
                            android:fontFamily="monospace"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchHardwareAccel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/brand_accent"
                        app:trackTint="@color/white_10"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white_05"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ADD WATERMARK"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:fontFamily="sans-serif-black"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OVERLAY APP SIGNATURE"
                            android:textColor="@color/text_medium_emphasis"
                            android:textSize="9sp"
                            android:layout_marginTop="4dp"
                            android:fontFamily="monospace"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchWatermark"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/brand_accent"
                        app:trackTint="@color/white_10"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/StealthLabel"
                android:text="MAINTENANCE"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white_05"
                app:strokeWidth="1dp"
                app:strokeColor="@color/white_10">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStorage"
                        style="@style/StealthActionRow"
                        android:text="  Storage Management"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        app:icon="@drawable/ic_folder"
                        app:iconTint="@color/brand_accent"/>

                    <View style="@style/StealthDivider" android:layout_marginHorizontal="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearHistory"
                        style="@style/StealthActionRow"
                        android:text="  Wipe All Cache"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/red_400"
                        app:icon="@drawable/ic_delete"
                        app:iconTint="@color/red_400"/>

                    <View style="@style/StealthDivider" android:layout_marginHorizontal="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAppInfo"
                        style="@style/StealthActionRow"
                        android:text="  System Info"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        app:icon="@android:drawable/ic_menu_info_details"
                        app:iconTint="@color/brand_accent"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>