<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/bg_deep_black">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_lock"
                app:tint="@color/brand_accent"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System Recovery"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter your registered email to reset your encryption key"
                android:textColor="#66FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginTop="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="48dp">

                <TextView
                    style="@style/StealthLabel"
                    android:text="RECOVERY EMAIL"
                    android:alpha="0.6" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_input"
                    android:hint="user@nexus.cloud"
                    android:textColorHint="@color/white_20"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="20dp"
                    android:inputType="textEmailAddress"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="SEND RECOVERY LINK"
                android:backgroundTint="@color/brand_accent"
                android:textColor="#000000"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                app:cornerRadius="12dp"
                android:layout_marginTop="40dp" />

            <TextView
                android:id="@+id/btnBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABORT AND RETURN TO LOGIN"
                android:textColor="@color/white_30"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginTop="32dp"
                android:padding="16dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
