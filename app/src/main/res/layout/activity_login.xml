<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/bg_deep_black">

    <!-- Ambient Neon Glow -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:background="@drawable/bg_neon_glow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-150dp"
        android:layout_marginEnd="-150dp"
        android:alpha="0.15" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:paddingBottom="40dp">

            <!-- Logo Section -->
            <ImageView
                android:id="@+id/imgAppLogo"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/app_logo"
                android:layout_marginBottom="24dp"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tvLogo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STUDIO_V4"
                android:textColor="@color/brand_accent"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.4"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Authorize Access"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="40dp" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in to continue to Creative Cloud"
                android:textColor="#66FFFFFF"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp" />

            <!-- Login Inputs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="56dp">

                <TextView
                    style="@style/StealthLabel"
                    android:text="CREDENTIALS"
                    android:alpha="0.6"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_glass_input"
                    android:hint="Email or Username"
                    android:textColorHint="@color/white_20"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="20dp"
                    android:inputType="textEmailAddress"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_glass_input"
                    android:hint="Encryption Password"
                    android:textColorHint="@color/white_20"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="20dp"
                    android:inputType="textPassword"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FORGOT PASSWORD?"
                    android:textColor="@color/brand_accent"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:layout_gravity="end"
                    android:layout_marginTop="16dp"
                    android:padding="8dp" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="AUTHENTICATE"
                android:backgroundTint="@color/brand_accent"
                android:textColor="#000000"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.2"
                app:cornerRadius="12dp"
                android:layout_marginTop="32dp"
                app:elevation="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDemoLogin"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="ACCESS DEMO MODE"
                android:backgroundTint="@android:color/transparent"
                android:textColor="@color/brand_accent"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                app:cornerRadius="12dp"
                android:layout_marginTop="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/brand_accent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="40dp">
                
                <View 
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/white_10"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OR CONNECT VIA"
                    android:textColor="@color/white_20"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:layout_marginHorizontal="16dp"/>
                <View 
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/white_10"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnGoogle"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/white_05"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/white_10">
                   <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_google"
                    android:scaleType="fitCenter"
                    android:tint="#00FFFF" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <TextView
                android:id="@+id/tvSignUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW TO NEXUS? CREATE ACCOUNT"
                android:textColor="@color/brand_accent"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginTop="48dp"
                android:padding="16dp" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
