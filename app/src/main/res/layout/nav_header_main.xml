<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

<View
android:id="@+id/bgHeroGradient"
android:layout_width="match_parent"
android:layout_height="0dp"
app:layout_constraintTop_toTopOf="parent"
app:layout_constraintBottom_toBottomOf="parent"
android:background="@android:color/transparent"
android:alpha="0.5" />

<View
android:id="@+id/bgGridPattern"
android:layout_width="match_parent"
android:layout_height="0dp"
app:layout_constraintTop_toTopOf="parent"
app:layout_constraintBottom_toBottomOf="parent"
android:alpha="0.5"
android:background="@drawable/bg_grid_pattern" />

<com.google.android.material.card.MaterialCardView
android:id="@+id/logoCard"
android:layout_width="60dp"
android:layout_height="60dp"
android:layout_marginStart="32dp"
android:layout_marginTop="48dp"
app:cardBackgroundColor="@color/white_05"
app:cardCornerRadius="12dp"
app:cardElevation="0dp"
app:strokeWidth="1.5dp"
app:strokeColor="@color/white_10"
app:layout_constraintTop_toTopOf="parent"
app:layout_constraintStart_toStartOf="parent">

<ImageView
    android:id="@+id/logo"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="2dp"
    android:src="@drawable/app_logo"
    android:scaleType="fitXY"
    android:contentDescription="@null"/>
</com.google.android.material.card.MaterialCardView>

<TextView
android:id="@+id/tvAppName"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:layout_marginStart="32dp"
android:layout_marginTop="12dp"
android:text="@string/app_name"
android:textSize="32sp"
android:fontFamily="sans-serif-black"
android:letterSpacing="0.02"
android:textAllCaps="true"
android:textColor="@color/text_primary"
app:layout_constraintStart_toStartOf="parent"
app:layout_constraintTop_toBottomOf="@id/logoCard" />

<TextView
android:id="@+id/tvMerchantVerified"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="@string/merchant_verified"
android:textSize="9sp"
android:fontFamily="monospace"
android:letterSpacing="0.2"
android:textColor="@color/brand_accent"
android:background="@drawable/bg_tag_glass"
android:paddingHorizontal="6dp"
android:paddingVertical="1dp"
app:layout_constraintStart_toStartOf="@id/tvAppName"
app:layout_constraintTop_toBottomOf="@id/tvAppName" />

    <!-- 3. Attached this last view to the bottom of the container with your desired padding -->
<TextView
android:id="@+id/tvProActive"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:layout_marginTop="4dp"
android:layout_marginBottom="8dp"
android:text="@string/pro_active"
android:textSize="9sp"
android:fontFamily="monospace"
android:letterSpacing="0.2"
android:textColor="@color/brand_accent"
android:background="@drawable/bg_tag_glass"
android:paddingHorizontal="6dp"
android:paddingVertical="1dp"
app:layout_constraintStart_toStartOf="@id/tvAppName"
app:layout_constraintTop_toBottomOf="@id/tvMerchantVerified"
app:layout_constraintBottom_toTopOf="@id/bottomDivider" />

<View
android:id="@+id/bottomDivider"
android:layout_width="match_parent"
android:layout_height="1dp"
app:layout_constraintBottom_toBottomOf="parent"
android:background="@color/white_10" />

    </androidx.constraintlayout.widget.ConstraintLayout>
