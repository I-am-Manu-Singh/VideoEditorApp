<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.VideoEditorApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/stealth_cyan</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/bg_dark_elevated</item>
        <item name="colorOnPrimaryContainer">@color/text_high_emphasis</item>

        <item name="colorSecondary">@color/stealth_cyan</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/white_10</item>
        <item name="colorOnSecondaryContainer">@color/stealth_cyan</item>

        <item name="colorTertiary">@color/status_success</item>
        <item name="colorOnTertiary">@color/white</item>

        <item name="colorError">@color/status_error</item>
        <item name="colorOnError">@color/white</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="p">shortEdges</item>

        <item name="android:textColorPrimary">@color/text_high_emphasis</item>
        <item name="android:textColorSecondary">@color/text_medium_emphasis</item>

        <item name="colorSurface">@color/bg_deep_black</item>
        <item name="colorOnSurface">@color/text_high_emphasis</item>
        <item name="colorSurfaceVariant">@color/bg_dark_surface</item>
        <item name="colorOnSurfaceVariant">@color/text_medium_emphasis</item>
        <item name="colorOutline">@color/white_20</item>
        <item name="colorOutlineVariant">@color/white_10</item>

        <item name="android:windowBackground">@color/bg_deep_black</item>

        <item name="android:alertDialogTheme">@style/Theme.VideoEditorApp.Dialog</item>
        <item name="materialAlertDialogTheme">@style/Theme.VideoEditorApp.Dialog</item>
    </style>

    <style name="NavIconStealth">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:tint">#FFFFFF</item>
        <item name="android:alpha">0.7</item>
    </style>

</resources>